{
  "id": "html-1771910761899",
  "title": "Articulación de los componentes",
  "type": "html",
  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Justificación - Oferta Internacional - Unitrópico</title>\n  <!-- Fuente Montserrat y CSS base -->\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n  <style>\n    /* =========================\n       ESTILOS ADICIONALES\n    ========================= */\n    html,\n    body {\n      height: 100%;\n      margin: 0;\n      overflow-x: hidden;\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    /* Navbar */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n    }\n\n    .navbar-img img {\n      width: 100%;\n      height: auto;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal */\n    .container {\n      max-width: 1100px;\n      margin: 30px auto;\n      padding: 0 25px;\n    }\n\n    /* Estilos para Estrategias de flexibilización */\n    .section-header-line {\n      margin-bottom: 40px;\n      text-align: center;\n      padding-top: 10px;\n    }\n\n    .section-header-line h2 {\n      font-weight: 400;\n      font-size: 2.2rem;\n      line-height: 1.35;\n      color: #007580;\n      margin: 0 0 10px 0;\n    }\n\n    /* Estilos para el Icono Lateral */\n    .comp-icon-row {\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      margin-top: 80px;\n      margin-bottom: 90px;\n      gap: 30px;\n    }\n\n    .comp-icon-container {\n      width: 140px;\n      height: 140px;\n      background-color: #fcfcfc;\n      border-radius: 50%;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08), inset 0 2px 10px rgba(0, 0, 0, 0.02);\n      border: 3px solid #f2f2f2;\n    }\n\n    .comp-icon-container img {\n      width: 55%;\n      height: auto;\n    }\n\n    .comp-text-title {\n      font-size: 2.2rem;\n      font-weight: 700;\n      color: #007580;\n    }\n\n    @media (max-width: 768px) {\n      .container {\n        margin: 15px;\n        padding: 0 15px;\n      }\n\n      .comp-icon-row {\n        flex-direction: column;\n        gap: 15px;\n      }\n\n      .comp-text-title {\n        font-size: 1.8rem;\n      }\n\n      .section-header-line h2 {\n        font-size: 1.5rem !important;\n      }\n\n      .line-gold {\n        width: 100% !important;\n        max-width: 550px;\n      }\n\n      .line-gray {\n        width: 80% !important;\n        max-width: 450px;\n      }\n    }\n\n    /* =========================================\n       NUEVO LAYOUT: ARTICULACIÓN DE LOS COMPONENTES\n       ========================================= */\n    .articulacion-header {\n      margin-top: 50px;\n      margin-bottom: 20px;\n      text-align: center;\n    }\n\n    .articulacion-header h2 {\n      font-weight: 700;\n      font-size: 2.2rem;\n      color: #007580;\n      margin: 0 0 10px 0;\n    }\n    .articulacion-header h2 span {\n      font-weight: 300;\n    }\n\n    /* Contenedor principal del diagrama */\n    .articulacion-container {\n      position: relative;\n      width: 100%;\n      max-width: 1060px;\n      margin: 0 auto 100px auto;\n      min-height: 520px;\n    }\n\n    /* Caja verde genérica */\n    .art-box {\n      background-color: #00594e;\n      border-radius: 10px;\n      color: white;\n      text-align: center;\n      padding: 20px 25px;\n      font-weight: 600;\n      font-size: 0.95rem;\n      line-height: 1.4;\n      width: 300px;\n      box-shadow: 0 4px 10px rgba(0,0,0,0.15);\n      position: absolute;\n      z-index: 2;\n    }\n\n    /* Posiciones específicas de las cajas */\n    .box-top {\n      top: 0;\n      left: 50%;\n      transform: translateX(-50%);\n    }\n\n    .box-left {\n      top: 55%;\n      left: 0;\n      transform: translateY(-50%);\n    }\n\n    .box-right {\n      top: 55%;\n      right: 0;\n      transform: translateY(-50%);\n    }\n\n    /* Círculo central */\n    .art-circle {\n      position: absolute;\n      top: 55%;\n      left: 50%;\n      transform: translate(-50%, -50%);\n      width: 220px;\n      height: 220px;\n      background: radial-gradient(circle, #ffffff 50%, #f0f0f0 100%);\n      border-radius: 50%;\n      box-shadow: 0 10px 20px rgba(0,0,0,0.08), inset 0 0 0 4px #ffffff;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n      padding: 30px;\n      color: #007580;\n      font-weight: 600;\n      font-size: 1rem;\n      z-index: 2;\n    }\n\n    /* Base sutil dorada para el círculo */\n    .art-circle::after {\n      content: '';\n      position: absolute;\n      top: 0; left: 0; right: 0; bottom: 0;\n      border-radius: 50%;\n      border: 1px solid #e2d7ba;\n      z-index: -1;\n      margin: -2px;\n    }\n\n    /* Flechas doradas (CSS shapes) */\n    .arrow {\n      position: absolute;\n      z-index: 1;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n    }\n\n    .arrow-body {\n      background-color: #c9b485;\n    }\n\n    .arrow-head {\n      width: 0;\n      height: 0;\n      border-style: solid;\n    }\n\n    /* Flecha apuntando abajo (Top -> Centro) */\n    .arrow-down {\n      top: 100px;\n      left: 50%;\n      transform: translateX(-50%);\n    }\n    .arrow-down .arrow-body {\n      width: 14px;\n      height: 30px;\n    }\n    .arrow-down .arrow-head {\n      border-width: 18px 18px 0 18px;\n      border-color: #c9b485 transparent transparent transparent;\n    }\n\n    /* Flecha apuntando derecha (Izquierda -> Centro) */\n    .arrow-right {\n      top: 55%;\n      left: 320px;\n      transform: translateY(-50%);\n      flex-direction: row;\n    }\n    .arrow-right .arrow-body {\n      height: 14px;\n      width: 50px;\n    }\n    .arrow-right .arrow-head {\n      border-width: 18px 0 18px 18px;\n      border-color: transparent transparent transparent #c9b485;\n    }\n\n    /* Flecha apuntando izquierda (Derecha -> Centro) */\n    .arrow-left {\n      top: 55%;\n      right: 320px;\n      transform: translateY(-50%);\n      flex-direction: row-reverse;\n    }\n    .arrow-left .arrow-body {\n      height: 14px;\n      width: 50px;\n    }\n    .arrow-left .arrow-head {\n      border-width: 18px 18px 18px 0;\n      border-color: transparent #c9b485 transparent transparent;\n    }\n\n    @media (max-width: 900px) {\n      .articulacion-container {\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        gap: 20px;\n        position: static;\n      }\n      .art-box {\n        position: static;\n        transform: none;\n        width: 100%;\n        max-width: 320px;\n      }\n      .art-circle {\n        position: static;\n        transform: none;\n        order: -1; /* Poner el circulo primero */\n        margin-bottom: 20px;\n      }\n      .arrow {\n        display: none; /* Ocultar flechas en móvil por simplicidad */\n      }\n    }\n  </style>\n</head>\n\n<body>\n  <!-- Navbar de imagen -->\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"container\">\n    <!-- Título del artículo (alineado izquierda) -->\n    <div class=\"top-left-title subtitulo text-verde-1\">\n      <span class=\"text-bronce-1\">2.5.3.2.3.2.4. Aspectos curriculares -</span> c) Componentes de interacción\n    </div>\n\n    <!-- Encabezado centrado -->\n    <div class=\"articulacion-header\">\n      <h2><span>Articulación de </span>los componentes</h2>\n      <div style=\"display: flex; flex-direction: column; align-items: center; gap: 0px;\">\n        <div class=\"line-gold\" style=\"width: 450px; height: 3px; background-color: #ba9b5e; border-radius: 2px;\"></div>\n        <div class=\"line-gray\" style=\"width: 400px; height: 6px; background-color: #e0e0e0; border-radius: 3px;\"></div>\n      </div>\n    </div>\n\n    <!-- Contenedor del Diagrama -->\n    <div class=\"articulacion-container\">\n      \n      <!-- Box Top -->\n      <div class=\"art-box box-top\">\n        Análisis de la evolución de<br>la disciplina en diversos<br>contextos académicos y<br>profesionales\n      </div>\n\n      <!-- Arrow Down -->\n      <div class=\"arrow arrow-down\">\n        <div class=\"arrow-body\"></div>\n        <div class=\"arrow-head\"></div>\n      </div>\n\n      <!-- Box Left -->\n      <div class=\"art-box box-left\">\n        Revisión constante del<br>entorno educativo<br>nacional e internacional\n      </div>\n\n      <!-- Arrow Right -->\n      <div class=\"arrow arrow-right\">\n        <div class=\"arrow-body\"></div>\n        <div class=\"arrow-head\"></div>\n      </div>\n\n      <!-- Circle Center -->\n      <div class=\"art-circle\">\n        Articulación de los<br>componentes<br>de interacción\n      </div>\n\n      <!-- Box Right -->\n      <div class=\"art-box box-right\">\n        Seguimiento<br>sistemático de los<br>egresados del<br>programa\n      </div>\n\n      <!-- Arrow Left -->\n      <div class=\"arrow arrow-left\">\n        <div class=\"arrow-body\"></div>\n        <div class=\"arrow-head\"></div>\n      </div>\n\n    </div>\n\n  </div>\n</body>\n\n</html>",
  "allowScripts": true,
  "hotspots": []
}