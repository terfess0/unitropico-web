  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Información General del Programa - Ingeniería en IA</title>\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n  <style>\n    /* ======================== */\n    /* IMAGEN DE FONDO GENERAL  */\n    /* ======================== */\n    body {\n      margin: 0;\n      padding: 0;\n      /* Reemplaza 'ruta/a/tu/imagen.jpg' con la URL de tu imagen de fondo */\n      background-image: url('../img/background-1.jpg');\n      background-size: cover;\n      background-attachment: fixed;\n      background-position: center;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    /* Navbar con imagen a todo el ancho */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n    }\n\n    .navbar-img img {\n      width: 100%;\n      height: auto;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal con fondo semitransparente para legibilidad */\n    .container {\n      max-width: 1100px;\n      margin: auto;\n      padding: 25px;\n      border-radius: 30px;\n    }\n\n    /* Estilo para el título de la sección (fondo verde claro) */\n    .section-header {\n      background-color: var(--verde-5);\n      padding: 10px 20px;\n      border-radius: 30px 30px 30px 30px;\n      margin-bottom: 25px;\n      display: inline-block;\n      width: auto;\n    }\n\n    /* Caja de la tabla con sombra y bordes redondeados */\n    .table-box {\n      border-radius: 20px;\n      overflow: hidden;\n      box-shadow: 0 8px 20px rgba(0, 89, 78, 0.1);\n      margin-bottom: 2rem;\n      background-color: white;\n    }\n\n    /* Estilos de la tabla */\n    .table-box table {\n      width: 100%;\n      border-collapse: collapse;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    .table-box th {\n      background-color: var(--verde-4);\n      color: var(--verde-1);\n      font-weight: 600;\n      padding: 14px 20px;\n      text-align: left;\n      font-size: 1rem;\n      width: 35%;\n    }\n\n    .table-box td {\n      background-color: white;\n      color: black;\n      padding: 14px 20px;\n      border-bottom: 1px solid var(--verde-5);\n    }\n\n    .table-box tr:last-child td {\n      border-bottom: none;\n    }\n\n    /* Espaciado del título superior */\n    .top-left-title {\n      margin-bottom: 20px;\n    }\n  </style>\n</head>\n\n<body>\n\n  <!-- Navbar de imagen -->\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"container\">\n    <!-- Título del artículo con clases del CSS base -->\n    <div class=\"top-left-title subtitulo text-verde-1\">\n      Artículo 2.5.3.2.3.2.2. Denominación del programa – Ficha Técnica\n    </div>\n\n    <!-- Sección con fondo verde claro para el título -->\n    <div class=\"section-header\">\n      <h2 class=\"titulo text-verde-1\" style=\"margin: 0;\">Información General del Programa</h2>\n    </div>\n\n    <!-- Tabla de información -->\n    <div class=\"table-box\">\n      <table>\n        <tbody>\n          <tr>\n            <th>Institución</th>\n            <td>Universidad Internacional del Trópico Americano</td>\n          </tr>\n          <tr>\n            <th>Lugar de desarrollo del programa</th>\n            <td>Yopal - Casanare</td>\n          </tr>\n          <tr>\n            <th>Nombre del programa</th>\n            <td>Ingeniería en Inteligencia Artificial</td>\n          </tr>\n          <tr>\n            <th>Título que otorga</th>\n            <td>Ingeniero(a) en Inteligencia Artificial</td>\n          </tr>\n          <tr>\n            <th>Norma interna de creación</th>\n            <td>Acuerdo CS No. 090 de 2025</td>\n          </tr>\n          <tr>\n            <th>Programa adscrito a</th>\n            <td>Facultad de Ingenierías</td>\n          </tr>\n          <tr>\n            <th>Nivel académico</th>\n            <td>Pregrado</td>\n          </tr>\n          <tr>\n            <th>Modalidad</th>\n            <td>Presencial</td>\n          </tr>\n          <tr>\n            <th>Número de créditos</th>\n            <td>148 créditos</td>\n          </tr>\n          <tr>\n            <th>Valor de la matrícula al iniciar el programa</th>\n            <td>1,5 S.M.L.M.V</td>\n          </tr>\n          <tr>\n            <th>Duración del programa</th>\n            <td>Nueve (9) semestres</td>\n          </tr>\n          <tr>\n            <th>Registro calificado único</th>\n            <td>No</td>\n          </tr>\n          <tr>\n            <th>Periocidad de admisión al programa</th>\n            <td>Semestral</td>\n          </tr>\n          <tr>\n            <th>No. de estudiantes primer periodo</th>\n            <td>60 estudiantes</td>\n          </tr>\n          <tr>\n            <th>Campo amplio</th>\n            <td>(06) Tecnologías de la información y la comunicación (UNESCO, 2016)</td>\n          </tr>\n          <tr>\n            <th>Campo específico</th>\n            <td>(061) Tecnologías de la información y la comunicación</td>\n          </tr>\n          <tr>\n            <th>Campo detallado</th>\n            <td>(0618) Programas interdisciplinares en TIC</td>\n          </tr>\n          <tr>\n            <th>Porcentaje de inclusión tecnológica</th>\n            <td>60%</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n\n</body>\n\n</html>",
