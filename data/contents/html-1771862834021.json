  "id": "html-1771862834021",
  "title": "Presentacion",
  "type": "html",
  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Presentación Inicial - Unitrópico</title>\n    <!-- Fuente Montserrat y CSS base -->\n    <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n    <style>\n        /* =========================\n       ESTILOS ADICIONALES\n    ========================= */\n        html,\n        body {\n            height: 100%;\n            margin: 0;\n            overflow-x: hidden;\n            background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n            background-size: cover;\n            font-family: 'Montserrat', sans-serif;\n        }\n\n        /* Navbar */\n        .navbar-img {\n            width: 100%;\n            background: var(--verde-1);\n            text-align: center;\n        }\n\n        .navbar-img img {\n            width: 100%;\n            height: auto;\n            max-height: 110px;\n            object-fit: contain;\n            display: block;\n        }\n\n        /* Contenedor principal */\n        .container {\n            max-width: 1200px;\n            margin: 20px auto;\n            padding: 0 40px;\n        }\n\n        /* Encabezado de sección centrado con dos líneas */\n        .section-header-line {\n            margin-bottom: 20px;\n            text-align: center;\n        }\n\n        .section-header-line h2 {\n            font-size: 2.5rem;\n            font-weight: 700;\n            color: var(--verde-1);\n            margin: 0 0 5px 0;\n            line-height: 1.2;\n        }\n\n        .lines-container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 0px;\n        }\n\n        .line-gold {\n            width: 300px;\n            height: 3px;\n            background-color: var(--bronce-1);\n            border-radius: 2px;\n        }\n\n        .line-gray {\n            width: 150px;\n            height: 6px;\n            background-color: #A0A0A0;\n            border-radius: 3px;\n        }\n\n        /* Layout Central */\n        .content-grid {\n            display: flex;\n            flex-direction: column;\n            gap: 40px;\n            align-items: center;\n            max-width: 900px;\n            margin: 0 auto;\n        }\n\n        /* Columnas */\n        .presentacion-column {\n            display: flex;\n            flex-direction: column;\n            animation: fadeInUp 0.8s ease-out;\n            background: rgba(255, 255, 255, 0.85);\n            /* Fondo blanco con transparencia */\n            backdrop-filter: blur(15px);\n            -webkit-backdrop-filter: blur(15px);\n            padding:5px 50px;\n            border-radius: 30px;\n            border: 1px solid rgba(255, 255, 255, 0.4);\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);\n            width: 100%;\n        }\n\n        .column-title {\n            font-size: 1.8rem;\n            font-weight: 700;\n            color: var(--verde-1);\n            margin-bottom: 0px;\n            text-align: center;\n            min-height: 4.4rem;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            border-bottom: 2px solid var(--bronce-1);\n            padding-bottom: 15px;\n        }\n\n        /* Estilos de los ítems */\n        .info-list {\n            display: flex;\n            flex-direction: column;\n            gap: 15px;\n        }\n\n        .info-item {\n            display: flex;\n            align-items: center;\n            font-size: 1.05rem;\n            line-height: 1.4;\n            padding: 5px 0;\n            border-bottom: 1px solid rgba(178, 155, 92, 0.25);\n            /* Divider suave bronce */\n        }\n\n        .info-item:last-child {\n            border-bottom: none;\n        }\n\n        .info-label {\n            font-weight: 700;\n            color: var(--verde-1);\n            text-align: right;\n            width: 48%;\n            padding-right: 20px;\n            flex-shrink: 0;\n            font-size: 0.95rem;\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n        }\n\n        .info-value {\n            font-weight: 500;\n            color: #444;\n            width: 52%;\n        }\n\n        /* Estilo especial para el Ministerio */\n        .ministerio-info {\n            text-align: center;\n            margin-top: 5px;\n            display: flex;\n            flex-direction: column;\n            gap: 0;\n        }\n\n        .ministerio-item {\n            padding: 5px 0;\n            border-bottom: 1px solid rgba(178, 155, 92, 0.25);\n        }\n\n        .ministerio-item:last-child {\n            border-bottom: none;\n        }\n\n        .ministerio-label {\n            font-weight: 700;\n            color: var(--verde-1);\n            text-align: right;\n            width: 48%;\n            padding-right: 20px;\n            flex-shrink: 0;\n            font-size: 0.95rem;\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n        }\n\n        .ministerio-value {\n            font-weight: 600;\n            font-size: 1.1rem;\n            color: #666;\n        }\n\n        /* Animaciones */\n        @keyframes fadeInUp {\n            from {\n                opacity: 0;\n                transform: translateY(20px);\n            }\n\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        /* Responsive */\n        @media (max-width: 900px) {\n            .content-grid {\n                grid-template-columns: 1fr;\n                gap: 40px;\n            }\n\n            .info-label {\n                width: 40%;\n            }\n\n            .info-value {\n                width: 60%;\n            }\n        }\n    </style>\n</head>\n\n<body>\n\n    <!-- Navbar de imagen -->\n    <div class=\"navbar-img\">\n        <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n    </div>\n\n    <div class=\"container\">\n\n        <!-- Encabezado centrado -->\n        <div class=\"section-header-line\">\n            <h2 class=\"titulo text-verde-1\">Presentación Inicial</h2>\n            <div class=\"lines-container\">\n                <div class=\"line-gold\"></div>\n                <div class=\"line-gray\"></div>\n            </div>\n        </div>\n\n        <!-- Contenido en dos columnas -->\n        <div class=\"content-grid\">\n\n            <!-- Izquierda: Ministerio -->\n            <div class=\"presentacion-column\">\n                <h3 class=\"column-title\">Ministerio de <br> Educación Nacional</h3>\n                <div class=\"ministerio-info\">\n                    <div class=\"ministerio-item\">\n                        <span class=\"ministerio-label\">PARES</span>\n                    </div>\n                    <div class=\"ministerio-item\">\n                        <span class=\"ministerio-label\">Coordinador :</span>\n                        <span class=\"ministerio-value\"></span>\n                    </div>\n                    <div class=\"ministerio-item\">\n                        <span class=\"ministerio-label\">Académico:</span>\n                        <span class=\"ministerio-value\"></span>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Derecha: Unitrópico -->\n            <div class=\"presentacion-column\">\n                <h3 class=\"column-title\">Unitrópico</h3>\n                <div class=\"info-list\">\n                    <div class=\"info-item\">\n                        <span class=\"info-label\">Rector:</span>\n                        <span class=\"info-value\">Oriol Jiménez Silva</span>\n                    </div>\n                    <div class=\"info-item\">\n                        <span class=\"info-label\">Vicerrectoría Académica:</span>\n                        <span class=\"info-value\">Alieth del Rocío Ávila Sanabria</span>\n                    </div>\n                    <div class=\"info-item\">\n                        <span class=\"info-label\">Vicerrectoría de Proyección Social:</span>\n                        <span class=\"info-value\">Oscar Mauricio Cruz Holguín</span>\n                    </div>\n                    <div class=\"info-item\">\n                        <span class=\"info-label\">Vicerrectoría de Investigación:</span>\n                        <span class=\"info-value\">Sindy Lorena Guatava Fernández</span>\n                    </div>\n                    <div class=\"info-item\">\n                        <span class=\"info-label\">Vicerrectoría Administrativa y Financiera:</span>\n                        <span class=\"info-value\">Claudia Patricia Manrique Vega</span>\n                    </div>\n                    <div class=\"info-item\">\n                        <span class=\"info-label\">Oficina de Relaciones y Cooperación Internacional:</span>\n                        <span class=\"info-value\">Kelly</span>\n                    </div>\n                    <div class=\"info-item\">\n                        <span class=\"info-label\">Oficina de Aseguramiento de la Calidad y la Acreditación:</span>\n                        <span class=\"info-value\">María Alejandra del Mar Guevara Peña</span>\n                    </div>\n                    <div class=\"info-item\">\n                        <span class=\"info-label\">Oficina Asesora de Planeación:</span>\n                        <span class=\"info-value\">Amanda Dueñas Cubides</span>\n                    </div>\n                    <div class=\"info-item\">\n                        <span class=\"info-label\">Bienestar Institucional:</span>\n                        <span class=\"info-value\">Karol Tatiana Barón Gómez</span>\n                    </div>\n                    <div class=\"info-item\">\n                        <span class=\"info-label\">Oficina Asesora de Prensa y Comunicaciones:</span>\n                        <span class=\"info-value\">Martha Isabel Cabezas Bolaños</span>\n                    </div>\n                </div>\n            </div>\n\n        </div>\n    </div>\n\n</body>\n\n</html>",
  "allowScripts": true,
  "hotspots": []
}