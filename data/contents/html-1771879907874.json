  "id": "html-1771879907874",
  "title": "Flexibilización",
  "type": "html",
  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Justificación - Oferta Internacional - Unitrópico</title>\n  <!-- Fuente Montserrat y CSS base -->\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n  <style>\n    /* =========================\n       ESTILOS ADICIONALES\n    ========================= */\n    html,\n    body {\n      height: 100%;\n      margin: 0;\n      overflow-x: hidden;\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    /* Navbar */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n    }\n\n    .navbar-img img {\n      width: 100%;\n      height: auto;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal */\n    .container {\n      max-width: 1100px;\n      margin: 30px auto;\n      padding: 0 25px;\n    }\n\n    /* Estilos para Asignaturas Optativas */\n    .optativas-desc {\n      font-size: 1.7rem;\n      font-weight: 500;\n      color: #007580;\n      text-align: center;\n      margin-top: 40px;\n      margin-bottom: 60px;\n      line-height: 1.4;\n    }\n\n    .optativas-desc strong {\n      color: #004b40;\n      font-weight: 700;\n    }\n\n    .optativas-grid {\n      display: flex;\n      justify-content: space-between;\n      gap: 20px;\n      margin-bottom: 50px;\n    }\n\n    .opt-card {\n      display: flex;\n      flex-direction: column;\n      flex: 1;\n      height: 100%;\n      box-shadow: 4px 6px 15px rgba(0, 0, 0, 0.15);\n    }\n\n    .opt-header {\n      color: white;\n      text-align: center;\n      font-weight: 700;\n      font-size: 1.2rem;\n      padding: 30px 20px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      min-height: 110px;\n      box-sizing: border-box;\n    }\n\n    /* Colores cabecera según imagen */\n    .header-red {\n      background-color: #b53846;\n    }\n\n    /* Rojo/Carmesí */\n    .header-ochre {\n      background-color: #cb893d;\n    }\n\n    /* Ocre/Mostaza */\n    .header-grey {\n      background-color: #837473;\n    }\n\n    /* Gris pardo */\n\n    .opt-body {\n      background-color: #3b7b6c;\n      /* Verde musgo claro */\n      color: white;\n      padding: 10px 20px 40px 20px;\n      flex-grow: 1;\n      font-size: 1rem;\n      line-height: 1.4;\n    }\n\n    .opt-body ul {\n      list-style-type: disc;\n      padding-left: 20px;\n      margin: 0;\n    }\n\n    .opt-body li {\n      margin-top: 15px;\n    }\n\n    /* Responsive */\n    @media (max-width: 900px) {\n      .optativas-grid {\n        flex-direction: column;\n      }\n\n      .opt-card {\n        margin-bottom: 20px;\n      }\n    }\n\n    @media (max-width: 768px) {\n      .container {\n        margin: 15px;\n        padding: 0 15px;\n      }\n    }\n  </style>\n</head>\n\n<body>\n  <!-- Navbar de imagen -->\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"container\">\n\n    <div class=\"container\">\n    <!-- Título del artículo (alineado izquierda) -->\n    <div class=\"top-left-title subtitulo text-verde-1\">\n      <span class=\"text-bronce-1\">Artículo 2.5.3.2.3.2.4.</span> Aspectos curriculares - a) Componentes formativos\n    </div>\n\n    <!-- Párrafo descriptivo superior -->\n    <div class=\"optativas-desc\">\n      Dentro de flexibilización, el programa de Ingeniería en Inteligencia Artificial <strong>propone<br>las siguientes\n        asignaturas optativas por líneas:</strong>\n    </div>\n\n    <!-- Contenido: Tres columnas de optativas -->\n    <div class=\"optativas-grid\">\n\n      <!-- Card 1: Inteligencia Artificial -->\n      <div class=\"opt-card\">\n        <div class=\"opt-header header-red\">\n          Inteligencia Artificial\n        </div>\n        <div class=\"opt-body\">\n          <ul>\n            <li>Visión Artificial Aplicada</li>\n            <li>Large Language Models<br>LLM</li>\n            <li>Agricultura de Precisión</li>\n          </ul>\n        </div>\n      </div>\n\n      <!-- Card 2: Ingeniería de Datos -->\n      <div class=\"opt-card\">\n        <div class=\"opt-header header-ochre\">\n          Ingeniería de Datos\n        </div>\n        <div class=\"opt-body\">\n          <ul>\n            <li>Ciberseguridad en<br>Sistemas de IA</li>\n            <li>Formulación de Proyectos<br>con Herramientas de IA</li>\n            <li>Analítica Predictiva en<br>Ciencia de Datos</li>\n          </ul>\n        </div>\n      </div>\n\n      <!-- Card 3: Hardware para Inteligencia Artificial -->\n      <div class=\"opt-card\">\n        <div class=\"opt-header header-grey\">\n          Hardware para<br>Inteligencia Artificial\n        </div>\n        <div class=\"opt-body\">\n          <ul>\n            <li>Sistemas Embebidos para<br>IA</li>\n            <li>Energías Renovables e IA</li>\n          </ul>\n        </div>\n      </div>\n\n    </div>\n\n  </div>\n</body>\n\n</html>",
  "allowScripts": true,
  "hotspots": []
}