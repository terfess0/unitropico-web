{
  "id": "html-1771809720777",
  "title": "Contenidos Curriculares",
  "type": "html",
  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Justificación - Oferta Internacional - Unitrópico</title>\n  <!-- Fuente Montserrat y CSS base -->\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n  <style>\n    /* =========================\n       ESTILOS ADICIONALES\n    ========================= */\n    html, body {\n      height: 100%;\n      margin: 0;\n      overflow-x: hidden;\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    /* Navbar */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n    }\n    .navbar-img img {\n      width: 100%;\n      height: auto;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal */\n    .container {\n      max-width: 1100px;\n      margin: auto;\n      padding: 0 25px;\n    }\n\n    /* Título del artículo (izquierda) */\n    .top-left-title {\n      margin-bottom: 20px;\n      color: var(--verde-1);\n    }\n\n    /* Encabezado de sección centrado con dos líneas */\n    .section-header-line {\n      margin-bottom: 40px;\n      text-align: center;\n    }\n    .section-header-line h2 {\n      font-size: 2.5rem;\n      font-weight: 700;\n      color: var(--verde-1);\n      margin: 0 0 15px 0;\n      line-height: 1.2;\n    }\n\n    /* Contenedor de las líneas (flex column para centrarlas) */\n    .lines-container {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 0px; /* espacio entre líneas */\n    }\n\n    /* Línea dorada (larga y delgada) */\n    .line-gold {\n      width: 300px;\n      height: 3px;\n      background-color: var(--bronce-1);\n      border-radius: 2px;\n    }\n\n    /* Línea gris (más corta y más alta) */\n    .line-gray {\n      width: 150px;\n      height: 6px;\n      background-color: #A0A0A0; /* gris suave, puedes cambiarlo por --bronce-4 si prefieres */\n      border-radius: 3px;\n    }\n\n    /* --- Estilos para los Árboles Pequeños (Praxis, Integral, Electivas) --- */\n    .trees-container {\n      display: flex;\n      justify-content: center;\n      align-items: flex-end;\n      gap: 30px;\n      margin-top: 40px;\n      margin-bottom: 50px;\n      width: 100%;\n      flex-wrap: wrap; /* Permitir que bajen en móviles */\n    }\n\n    .small-tree {\n      display: flex;\n      justify-content: center;\n    }\n\n    .small-tree ul {\n      padding-top: 20px; \n      position: relative;\n      display: flex;\n      justify-content: center;\n      padding-left: 0;\n      margin: 0;\n    }\n\n    .small-tree li {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      list-style-type: none;\n      position: relative;\n      padding: 20px 15px 0 15px;\n    }\n\n    /* Conectores horizontales superiores */\n    .small-tree li::before, .small-tree li::after {\n      content: '';\n      position: absolute; \n      top: 0; \n      right: 50%;\n      border-top: 2px solid #5A8AC6;\n      width: 50%; \n      height: 20px;\n    }\n    .small-tree li::after {\n      right: auto; \n      left: 50%;\n      border-left: 2px solid #5A8AC6;\n    }\n\n    /* Raiz */\n    .small-tree li:only-child::after, .small-tree li:only-child::before {\n      display: none;\n    }\n    .small-tree li:only-child { padding-top: 0; }\n\n    /* Puntas */\n    .small-tree li:first-child::before, .small-tree li:last-child::after {\n      border: 0 none;\n    }\n    .small-tree li:last-child::before {\n      border-right: 2px solid #5A8AC6;\n    }\n    \n    /* Conector vertical bajando del padre */\n    .small-tree ul ul::before {\n      content: '';\n      position: absolute; \n      top: 0; \n      left: 50%;\n      border-left: 2px solid #5A8AC6;\n      width: 0; \n      height: 20px;\n      margin-left: -1px;\n    }\n\n    /* Estilos para el nuevo formato en columnas (Praxis Investigativa) */\n    .courses-wrapper {\n      display: flex;\n      flex-direction: row;\n      margin-bottom: 50px;\n      width: 100%;\n      align-items: stretch;\n      gap: 15px;\n    }\n\n    .vertical-label {\n      writing-mode: vertical-rl;\n      transform: rotate(180deg);\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      padding: 15px 15px;\n      margin-right: 5px;\n      color: #FFFFFF;\n      font-weight: 700;\n      font-size: 1.15rem;\n      letter-spacing: 1px;\n    }\n\n    .courses-grid {\n      display: flex;\n      flex: 1;\n      gap: 15px;\n    }\n\n    .course-column {\n      flex: 1;\n      display: flex;\n      flex-direction: column;\n    }\n\n    .course-header {\n      display: flex;\n      align-items: center;\n      color: #FFFFFF;\n      font-weight: 700;\n      font-size: 1.05rem;\n      padding: 12px 15px;\n      min-height: 60px;\n      line-height: 1.2;\n      border: 3px solid #6C9BC9;\n    }\n\n    .square-white {\n      width: 14px;\n      height: 14px;\n      background-color: #FFFFFF;\n      margin-right: 12px;\n      flex-shrink: 0;\n    }\n\n    .course-list {\n      list-style: none;\n      padding: 0;\n      margin: 15px 0 0 0;\n      display: flex;\n      flex-direction: column;\n      gap: 12px;\n    }\n\n    .course-list li {\n      display: flex;\n      align-items: flex-start;\n      font-weight: 500;\n      font-size: 0.85rem;\n      line-height: 1.3;\n    }\n\n    .square-outline {\n      width: 14px;\n      height: 14px;\n      border: 3px solid #6C9BC9;\n      margin-right: 8px;\n      margin-top: 3px;\n      flex-shrink: 0;\n      background-color: transparent;\n    }\n\n    .border-blue { border-color: #5A8AC6; }\n\n    /* Nodos de los arboles pequeños */\n    .st-node {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      position: relative;\n      z-index: 2;\n    }\n    \n    .st-node-root { width: 140px; }\n    .st-node-child { width: 130px; } \n\n    .st-title {\n      width: 100%;\n      color: #FFFFFF;\n      text-align: center;\n      padding: 8px 6px;\n      font-weight: 700;\n      font-size: 0.8rem;\n      min-height: 50px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      line-height: 1.2;\n    }\n\n    .st-subtitle {\n      background-color: #FFFFFF;\n      border: 1px solid #5A8AC6;\n      color: #333333;\n      padding: 2px 4px;\n      font-size: 0.65rem;\n      font-weight: 500;\n      margin-top: -8px;\n      z-index: 3;\n      position: relative;\n      white-space: nowrap;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n\n    /* Colores Específicos de los Nuevos Árboles */\n    .bg-st-praxis-root { background-color: #0088B4; }\n    .bg-st-praxis-c1 { background-color: #3366CC; }\n    .bg-st-praxis-c2 { background-color: #9999FF; }\n    .bg-st-praxis-c3 { background-color: #8C8CB8; }\n\n    .bg-st-integral-root { background-color: #9B2945; }\n    .bg-st-integral-c1 { background-color: #A35ECA; }\n    .bg-st-integral-c2 { background-color: #FF7575; }\n\n    .bg-st-eleccion-root { background-color: #B28B5C; } /* Color mostaza/dorado */\n    .bg-st-eleccion-c1 { background-color: #C09B66; }\n\n    .color-teal { color: var(--verde-1, #00563F); }\n    .color-gold { color: var(--bronce-1, #B29B5C); }\n    .color-arrow { color: #555555; margin: 0 2px; }\n    .color-gray { color: #555555; }\n    .color-blue-pct { color: #2A5BA1; font-weight: 700; } /* Porcentaje azul */\n    .color-gold-cred { color: #B29B5C; font-weight: 700; } /* Creditos dorado */\n\n    @media (max-width: 768px) {\n      .container {\n        margin: 15px;\n        padding: 0 15px;\n      }\n      .section-header-line h2 { font-size: 2rem; }\n      .line-gold { width: 200px; }\n      .line-gray { width: 100px; }\n      \n      .courses-wrapper {\n        flex-direction: column;\n        align-items: center;\n      }\n      .vertical-label {\n        writing-mode: horizontal-tb;\n        transform: rotate(0deg);\n        width: 100%;\n        margin-right: 0;\n        margin-bottom: 20px;\n        padding: 10px;\n      }\n      .courses-grid {\n        flex-direction: column;\n        width: 100%;\n        gap: 30px;\n      }\n\n      .trees-container {\n        flex-direction: column;\n        align-items: center;\n        gap: 50px;\n      }\n    }\n  </style>\n</head>\n<body>\n  <!-- Navbar de imagen -->\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"container\">\n    <!-- Título del artículo (alineado izquierda) -->\n    <div class=\"top-left-title subtitulo text-verde-1\">\n      <span class=\"text-bronce-1\">Artículo 2.5.3.2.3.2.5.</span> Organización de actividades académicas y proceso formativo\n    </div>\n\n    <!-- Encabezado \"Estado de la Oferta Internacional\" centrado con dos líneas -->\n    <div class=\"section-header-line\">\n      \n      <h2><span style=\"margin:0px;\" class=\"text-verde-2   \">Contenidos </span>  Curriculares</h2>\n      <div class=\"lines-container\">\n        <div class=\"line-gold\"></div>\n        <div class=\"line-gray\"></div>\n      </div>\n    </div>\n\n    <!-- Bloque 1: Formación Integral (2 columnas) -->\n    <div class=\"courses-wrapper\" style=\"margin-bottom: 30px;\">\n      \n      <!-- Etiqueta Lateral -->\n      <div class=\"vertical-label\" style=\"background-color: #9B2945;\">\n        Formación Integral\n      </div>\n\n      <div class=\"courses-grid\" style=\"gap: 15px; max-width: 800px;\">\n        \n        <!-- Columna 1 -->\n        <div class=\"course-column\">\n          <div class=\"course-header\" style=\"background-color: #A35ECA;\">\n            <span class=\"square-white\"></span>\n            Competencias<br>Genéricas\n          </div>\n          <ul class=\"course-list\">\n            <li class=\"color-teal\"><span class=\"square-outline border-blue\"></span>Comprensión y producción de textos I</li>\n            <li class=\"color-gold\"><span class=\"square-outline border-blue\"></span>Comprensión y producción de textos II</li>\n            <li class=\"color-teal\"><span class=\"square-outline border-blue\"></span>Pensamiento Matemático</li>\n            <li class=\"color-gold\"><span class=\"square-outline border-blue\"></span>Constitución política y ciudadana</li>\n            <li class=\"color-teal\"><span class=\"square-outline border-blue\"></span>Optativa de competencia genérica I</li>\n          </ul>\n        </div>\n\n        <!-- Columna 2 -->\n        <div class=\"course-column\">\n          <div class=\"course-header\" style=\"background-color: #FF7575;\">\n            <span class=\"square-white\"></span>\n            Identidad<br>Institucional\n          </div>\n          <ul class=\"course-list\">\n            <li class=\"color-teal\"><span class=\"square-outline border-blue\"></span>Cátedra de la Orinoquia</li>\n            <li class=\"color-gold\"><span class=\"square-outline border-blue\"></span>Optativa de Identidad Institucional I</li>\n            <li class=\"color-teal\"><span class=\"square-outline border-blue\"></span>Optativa de Identidad Institucional II</li>\n          </ul>\n        </div>\n\n      </div>\n    </div>\n\n  </div>\n\n  <!-- Badge Vigilada MinEducación (comentado) -->\n  <!-- <div class=\"vigilada\">– Vigilada MinEducación –</div> -->\n</body>\n</html>",
  "allowScripts": true,
  "hotspots": []
}