  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Justificación - Oferta Internacional - Unitrópico</title>\n  <!-- Fuente Montserrat y CSS base -->\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n  <style>\n    /* =========================\n       ESTILOS ADICIONALES\n    ========================= */\n    html,\n    body {\n      height: 100%;\n      margin: 0;\n      overflow-x: hidden;\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    /* Navbar */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n    }\n\n    .navbar-img img {\n      width: 100%;\n      height: auto;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal */\n    .container {\n      max-width: 1100px;\n      margin: 30px auto;\n      padding: 0 25px;\n    }\n\n    /* Estilos para Estrategias de flexibilización */\n    .section-header-line {\n      margin-bottom: 40px;\n      text-align: center;\n      padding-top: 10px;\n    }\n\n    .section-header-line h2 {\n      font-weight: 400;\n      font-size: 2.2rem;\n      line-height: 1.35;\n      color: #007580;\n      margin: 0 0 10px 0;\n    }\n\n    /* Estilos para el Icono Lateral */\n    .comp-icon-row {\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      margin-top: 80px;\n      margin-bottom: 90px;\n      gap: 30px;\n    }\n\n    .comp-icon-container {\n      width: 140px;\n      height: 140px;\n      background-color: #fcfcfc;\n      border-radius: 50%;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08), inset 0 2px 10px rgba(0, 0, 0, 0.02);\n      border: 3px solid #f2f2f2;\n    }\n\n    .comp-icon-container img {\n      width: 55%;\n      height: auto;\n    }\n\n    .comp-text-title {\n      font-size: 2.2rem;\n      font-weight: 700;\n      color: #007580;\n    }\n\n    @media (max-width: 768px) {\n      .container {\n        margin: 15px;\n        padding: 0 15px;\n      }\n\n      .comp-icon-row {\n        flex-direction: column;\n        gap: 15px;\n      }\n\n      .comp-text-title {\n        font-size: 1.8rem;\n      }\n\n      .section-header-line h2 {\n        font-size: 1.5rem !important;\n      }\n\n      .line-gold {\n        width: 100% !important;\n        max-width: 550px;\n      }\n\n      .line-gray {\n        width: 80% !important;\n        max-width: 450px;\n      }\n    }\n\n    }\n\n    /* =========================================\n       NUEVO LAYOUT: AMBIENTES DE APRENDIZAJE\n       ========================================= */\n    .ambientes-container {\n      width: 100%;\n      max-width: 1000px;\n      margin: 0 auto;\n      display: flex;\n      flex-direction: column;\n      gap: 15px;\n    }\n\n    /* Caja gris superior */\n    .amb-top-box {\n      background-color: #d9d9d9;\n      border-radius: 15px;\n      padding: 25px 30px;\n      font-size: 1.05rem;\n      line-height: 1.5;\n      color: #333;\n      text-align: left;\n    }\n\n    .amb-top-box strong {\n      color: #00594e;\n    }\n\n    /* Contenedor fila intermedia (Verdes) */\n    .amb-mid-row {\n      display: flex;\n      gap: 15px;\n    }\n\n    /* Cajas verdes medias */\n    .amb-mid-box {\n      flex: 1;\n      background-color: #00594e;\n      border-radius: 15px;\n      color: white;\n      text-align: center;\n      display: flex;\n      flex-direction: column;\n      justify-content: center;\n      padding: 20px 15px;\n    }\n\n    .amb-mid-box-title {\n      font-weight: 700;\n      font-size: 1.1rem;\n      text-transform: uppercase;\n      margin-bottom: 5px;\n    }\n\n    .amb-mid-box-subtitle {\n      font-weight: 400;\n      font-size: 0.95rem;\n    }\n\n    /* Contenedor fila inferior (Doradas) */\n    .amb-bottom-row {\n      display: flex;\n      gap: 10px;\n      justify-content: space-between;\n    }\n\n    /* Contenedores de botones limitados por sus padres verdes */\n    .amb-bottom-group {\n      display: flex;\n      gap: 10px;\n      flex: 1;\n    }\n\n    /* Botones dorados */\n    .amb-gold-btn {\n      flex: 1;\n      background-color: #bba974;\n      border-radius: 15px;\n      color: white;\n      font-size: 0.85rem;\n      font-weight: 600;\n      text-align: center;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      padding: 15px 5px;\n      aspect-ratio: 1 / 1; /* Para hacerlos cuadrados */\n      box-shadow: 0 4px 6px rgba(0,0,0,0.1);\n      transition: transform 0.2s ease, filter 0.2s ease;\n      cursor: pointer;\n    }\n\n    .amb-gold-btn:hover {\n      transform: translateY(-5px);\n      filter: brightness(1.1);\n    }\n\n    @media (max-width: 768px) {\n      .amb-mid-row {\n        flex-direction: column;\n      }\n      .amb-bottom-row {\n        flex-direction: column;\n      }\n      .amb-bottom-group {\n        flex-wrap: wrap;\n        justify-content: center;\n      }\n      .amb-gold-btn {\n        flex: 1 1 45%;\n        aspect-ratio: auto;\n        padding: 20px 10px;\n      }\n    }\n  </style>\n</head>\n\n<body>\n  <!-- Navbar de imagen -->\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"container\">\n    <!-- Título del artículo (alineado izquierda) -->\n    <div class=\"top-left-title subtitulo text-verde-1\" style=\"margin-bottom: 30px;\">\n      <span class=\"text-bronce-1\">2.5.3.2.3.2.4. Aspectos curriculares -</span> b) Componentes pedagógicos\n    </div>\n\n    <!-- Estructura Ambientes de Aprendizaje -->\n    <div class=\"ambientes-container\">\n      \n      <!-- Caja Superior Gris -->\n      <div class=\"amb-top-box\">\n        <strong>AMBIENTES DE APRENDIZAJE:</strong> Espacio o entorno tanto físicos como virtuales que proporcionan las condiciones necesarias para descubrir, comprender, problematizar y asimilar los temas educativos. Estructurados en cuatro componentes fundamentales <strong>Información, Interacción, Producción y Exhibición.</strong>\n      </div>\n\n      <!-- Fila Intermedia Verde -->\n      <div class=\"amb-mid-row\">\n        <!-- Verde Izquierda -->\n        <div class=\"amb-mid-box\">\n          <div class=\"amb-mid-box-title\">AMBIENTES FÍSICOS</div>\n        </div>\n        <!-- Verde Derecha -->\n        <div class=\"amb-mid-box\">\n          <div class=\"amb-mid-box-title\">AMBIENTES VIRTUALES Y HERRAMIENTAS TECNOLÓGICAS</div>\n          <div class=\"amb-mid-box-subtitle\">(Basadas en Tecnologías Transmisivas, Tecnologías Interactivas y Tecnologías Colaborativas)</div>\n        </div>\n      </div>\n\n      <!-- Fila Inferior Dorada -->\n      <div class=\"amb-bottom-row\">\n        \n        <!-- Botones debajo de \"Ambientes Físicos\" -->\n        <div class=\"amb-bottom-group\" style=\"flex: 1;\">\n          <div class=\"amb-gold-btn\">Laboratorios</div>\n          <div class=\"amb-gold-btn\">Biblioteca</div>\n          <div class=\"amb-gold-btn\">Salidas de campo</div>\n          <div class=\"amb-gold-btn\">Campus<br>Universitario</div>\n        </div>\n\n        <!-- Botones debajo de \"Ambientes Virtuales\" -->\n        <div class=\"amb-bottom-group\" style=\"flex: 1;\">\n          <div class=\"amb-gold-btn\">Suite Google</div>\n          <div class=\"amb-gold-btn\">Suite de<br>Office de MS</div>\n          <div class=\"amb-gold-btn\">Aulas<br>Informática</div>\n          <div class=\"amb-gold-btn\">LMS -<br>Learning<br>Management<br>System en la<br>Plataforma<br>Q10</div>\n        </div>\n\n      </div>\n\n    </div>\n\n  </div>\n</body>\n\n</html>",
  "allowScripts": true,
