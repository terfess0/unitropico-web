  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Justificación - Oferta Internacional - Unitrópico</title>\n  <!-- Fuente Montserrat y CSS base -->\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n  <style>\n    /* =========================\n       ESTILOS ADICIONALES\n    ========================= */\n    html,\n    body {\n      height: 100%;\n      margin: 0;\n      overflow-x: hidden;\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    /* Navbar */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n    }\n\n    .navbar-img img {\n      width: 100%;\n      height: auto;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal */\n    .container {\n      max-width: 1100px;\n      margin: 30px auto;\n      padding: 0 25px;\n    }\n\n    /* Estilos para la imagen de Malla Curricular */\n    .malla-wrapper {\n      text-align: center;\n      margin-top: 50px;\n      margin-bottom: 60px;\n    }\n\n    .malla-wrapper img {\n      width: 100%;\n      max-width: 200px;\n      /* Ajuste del icono central */\n      height: auto;\n    }\n\n    /* Responsive */\n    @media (max-width: 768px) {\n      .container {\n        margin: 15px;\n        padding: 0 15px;\n      }\n\n      .section-header-line h2 {\n        font-size: 1.5rem !important;\n      }\n\n      .line-gold {\n        width: 100% !important;\n        max-width: 550px;\n      }\n\n      .line-gray {\n        width: 80% !important;\n        max-width: 450px;\n      }\n    }\n  </style>\n</head>\n\n<body>\n  <!-- Navbar de imagen -->\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"container\">\n\n    <div class=\"container\">\n    <!-- Título del artículo (alineado izquierda) -->\n    <div class=\"top-left-title subtitulo text-verde-1\">\n      <span class=\"text-bronce-1\">Artículo 2.5.3.2.3.2.4.</span> Aspectos curriculares - a) Componentes formativos\n    </div>\n\n    <!-- Encabezado centrado de Malla Curricular -->\n    <div class=\"section-header-line\" style=\"margin-bottom: 30px; text-align: center; padding-top: 20px;\">\n      <h2 style=\"font-weight: 600; font-size: 2.3rem; line-height: 1.3; color: #007580; margin: 0 0 10px 0;\">\n        Malla Curricular\n      </h2>\n      <div style=\"display: flex; flex-direction: column; align-items: center; gap: 0px;\">\n        <div class=\"line-gold\" style=\"width: 550px; height: 3px; background-color: #ba9b5e; border-radius: 2px;\"></div>\n        <div class=\"line-gray\" style=\"width: 450px; height: 6px; background-color: #e0e0e0; border-radius: 3px;\"></div>\n      </div>\n    </div>\n\n    <!-- Contenido: Imagen de Malla Curricular -->\n    <div class=\"malla-wrapper\">\n      <img id=\"btnIrMalla\" src=\"../img/malla_curricular.png\" alt=\"Icono Malla Curricular Inteligencia Artificial\">\n    </div>\n\n  </div>\n  <script>\n    const btnPerfil = document.getElementById('btnIrMalla');\n    if (btnPerfil) {\n      btnPerfil.addEventListener('click', (e) => {\n        e.stopPropagation();\n        window.parent.postMessage({ type: 'NAVIGATE', targetId: 'content-1771879394828' }, '*');\n      });\n    }\n  </script>\n</body>\n\n\n\n</html>",
