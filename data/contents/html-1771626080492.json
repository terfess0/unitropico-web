{
  "id": "html-1771626080492",
  "title": "Distribución Geográfica",
  "type": "html",
  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Justificación - Oferta Internacional - Unitrópico</title>\n  <!-- Fuente Montserrat y CSS base -->\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n  <!-- Plugin de etiquetas para Chart.js -->\n  <script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2\"></script>\n\n  <style>\n    /* =========================\n       ESTILOS ADICIONALES\n    ========================= */\n    html, body {\n      height: 100%;\n      margin: 0;\n      overflow-x: hidden;\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    /* Navbar */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n    }\n    .navbar-img img {\n      width: 100%;\n      height: auto;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal */\n    .container {\n      max-width: 1100px;\n      margin: 30px auto;\n      padding: 0 25px;\n    }\n\n    /* Título del artículo */\n    .top-left-title {\n      margin-bottom: 20px;\n    }\n\n    /* Encabezado de sección centrado con dos líneas */\n    .section-header-line {\n      margin-bottom: 40px;\n      text-align: center;\n    }\n    .section-header-line h2 {\n      font-size: 2.5rem;\n      font-weight: 700;\n      color: var(--verde-1);\n      margin: 0 0 15px 0;\n      line-height: 1.2;\n    }\n\n    .lines-container {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 0px;\n    }\n\n    .line-gold {\n      width: 300px;\n      height: 3px;\n      background-color: var(--bronce-1);\n      border-radius: 2px;\n    }\n\n    .line-gray {\n      width: 150px;\n      height: 6px;\n      background-color: #A0A0A0;\n      border-radius: 3px;\n    }\n\n    /* ===== ESTILOS DE GRÁFICOS ===== */\n    .charts-stack {\n      display: flex;\n      flex-direction: column;\n      gap: 40px;\n      margin-top: 20px;\n    }\n\n    .chart-card {\n      background: white;\n      padding: 30px;\n      border-radius: 20px;\n      box-shadow: 0 10px 30px rgba(0, 89, 78, 0.05);\n      border: 1px solid rgba(204, 222, 220, 0.4);\n      animation: fadeIn 1s ease-out forwards;\n      opacity: 0;\n    }\n\n    .chart-card:nth-child(2) {\n      animation-delay: 0.3s;\n    }\n\n    .chart-title {\n      font-family: 'Montserrat', sans-serif;\n      font-weight: 600;\n      color: var(--verde-2);\n      font-size: 1.2rem;\n      text-align: center;\n      margin-bottom: 30px;\n    }\n\n    /* Gráfico de Barras personalizado (horizontal) */\n    .bar-chart-container {\n      display: flex;\n      height: 300px;\n      position: relative;\n    }\n\n    .y-axis-wrapper {\n      display: flex;\n      align-items: stretch;\n      margin-right: 10px;\n    }\n\n    .y-axis-label {\n      writing-mode: vertical-rl;\n      transform: rotate(180deg);\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--verde-1);\n      text-align: center;\n      margin-right: 8px;\n      padding-bottom: 25px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n\n    .y-axis {\n      display: flex;\n      flex-direction: column;\n      justify-content: space-between;\n      text-align: right;\n      padding-right: 15px;\n      font-size: 11px;\n      color: var(--verde-1);\n      font-weight: 600;\n      width: 120px;\n      padding-bottom: 25px;\n    }\n\n    .bars-area {\n      flex: 1;\n      display: flex;\n      flex-direction: column;\n      justify-content: space-between;\n      border-left: 1px solid var(--verde-4);\n      border-bottom: 1px solid var(--verde-4);\n      padding-bottom: 5px;\n      position: relative;\n    }\n\n    .bar-row {\n      height: 22px;\n      display: flex;\n      align-items: center;\n    }\n\n    .bar {\n      height: 100%;\n      background-color: var(--bronce-1);\n      width: 0%;\n      transition: width 1.5s cubic-bezier(0.34, 1.56, 0.64, 1);\n      border-radius: 0 4px 4px 0;\n      box-shadow: 2px 0 10px rgba(181, 161, 96, 0.3);\n    }\n\n    .x-axis {\n      position: absolute;\n      bottom: -25px;\n      left: 0;\n      width: 100%;\n      display: flex;\n      justify-content: space-between;\n      font-size: 11px;\n      color: var(--verde-1);\n      font-weight: 600;\n    }\n\n    .axis-label-bottom {\n      text-align: center;\n      font-size: 14px;\n      color: var(--verde-1);\n      margin-top: 35px;\n      font-weight: 600;\n    }\n\n    /* Gráfico de Torta */\n    .pie-container {\n      height: 350px;\n      position: relative;\n    }\n\n    /* Fuente */\n    .footer-source {\n      margin-top: 50px;\n      border-top: 1px solid var(--verde-5);\n      border-bottom: 1px solid var(--verde-5);\n      padding: 15px 0;\n      text-align: center;\n      font-style: italic;\n      color: var(--verde-1);\n    }\n\n    @keyframes fadeIn {\n      from { opacity: 0; transform: translateY(15px); }\n      to   { opacity: 1; transform: translateY(0); }\n    }\n\n    /* Responsive */\n    @media (max-width: 768px) {\n      .container {\n        margin: 15px;\n        padding: 0 15px;\n      }\n      .section-header-line h2 {\n        font-size: 2rem;\n      }\n      .line-gold {\n        width: 200px;\n      }\n      .line-gray {\n        width: 100px;\n      }\n    }\n  </style>\n</head>\n<body>\n  <!-- Navbar de imagen -->\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"container\">\n    <!-- Título del artículo -->\n    <div class=\"top-left-title subtitulo text-verde-1\">\n      <span class=\"text-bronce-1\">Artículo 2.5.3.2.3.2.3</span> Justificación del programa – Estado de la oferta de educación – Análisis Estadístico de la Oferta\n    </div>\n\n    <!-- Distribución Geográfica -->\n    <div class=\"section-header-line\">\n      <h2 class=\"titulo\">Distribución Geográfica</h2>\n      <div class=\"lines-container\">\n        <div class=\"line-gold\"></div>\n        <div class=\"line-gray\"></div>\n      </div>\n    </div>\n\n    <!-- Contenedor de Gráficos en VERTICAL -->\n<div class=\"charts-stack\">\n\n  <!-- HISTOGRAMA -->\n  <div class=\"chart-card\">\n    <h3 class=\"chart-title subtitulo\">Distribución de número de créditos</h3>\n    <div class=\"pie-container\">\n      <canvas id=\"creditosChart\"></canvas>\n    </div>\n  </div>\n\n  <!-- BARRAS POR SEMESTRES -->\n  <div class=\"chart-card\">\n    <h3 class=\"chart-title subtitulo\">\n      Distribución de programas de Ingeniería en IA según semestres\n    </h3>\n    <div class=\"pie-container\">\n      <canvas id=\"semestresChart\"></canvas>\n    </div>\n  </div>\n\n</div>\n    <!-- Fuente (exactamente como en la imagen) -->\n    <div class=\"footer-source\">\n      <p class=\"parrafo\" style=\"font-style: italic;\">Fuente: Facultad de Ingenierías, 2025. Tomado Ministerio de Educación Nacional - Sistema Nacional de Información de la Educación Superior – SNIES (2025)</p>\n    </div>\n  </div>\n\n  <script>\nChart.defaults.font.family = 'Montserrat';\nChart.defaults.color = '#00594E';\n\n/* =========================\n   HISTOGRAMA DE CRÉDITOS\n========================= */\n\n// Datos simulados similares a la imagen\nconst creditosData = [130,135,138,140,142,144,139,141,143,145,155];\n\nconst ctxCreditos = document.getElementById('creditosChart').getContext('2d');\n\nnew Chart(ctxCreditos, {\n    type: 'bar',\n    data: {\n        labels: creditosData,\n        datasets: [\n            {\n                type: 'bar',\n                label: 'Frecuencia',\n                data: [1,1,1,3,4,2,1,2,1,1,1],\n                backgroundColor: 'rgba(181,161,96,0.55)',\n                borderColor: '#B5A160',\n                borderWidth: 1.5,\n                borderRadius: 6\n            },\n            {\n                type: 'line',\n                label: 'Tendencia',\n                data: [0.4,0.6,1,1.6,1.8,1.5,1.2,1,0.8,0.5,0.3],\n                borderColor: '#F59E0B',\n                backgroundColor: 'rgba(245,158,11,0.2)',\n                tension: 0.4,\n                fill: false,\n                pointRadius: 0,\n                borderWidth: 2\n            }\n        ]\n    },\n    options: {\n        responsive: true,\n        maintainAspectRatio: false,\n        scales: {\n            x: {\n                title: {\n                    display: true,\n                    text: 'Créditos',\n                    font: { weight: '600' }\n                },\n                grid: { display: false }\n            },\n            y: {\n                title: {\n                    display: true,\n                    text: 'Frecuencia',\n                    font: { weight: '600' }\n                },\n                beginAtZero: true\n            }\n        },\n        plugins: {\n            legend: { display: false }\n        },\n        animation: {\n            duration: 2000,\n            easing: 'easeOutQuart'\n        }\n    }\n});\n\n\n/* =========================\n   BARRAS POR SEMESTRES\n========================= */\n\nconst ctxSemestres = document.getElementById('semestresChart').getContext('2d');\n\nnew Chart(ctxSemestres, {\n    type: 'bar',\n    data: {\n        labels: ['8', '9'],\n        datasets: [{\n            data: [10, 4],\n            backgroundColor: [\n                '#5A4A3F',   // café oscuro como en imagen\n                '#D67C3C'    // naranja institucional\n            ],\n            borderRadius: 10,\n            barThickness: 120\n        }]\n    },\n    options: {\n        responsive: true,\n        maintainAspectRatio: false,\n        scales: {\n            x: {\n                title: {\n                    display: true,\n                    text: 'Duración en semestres',\n                    font: { weight: '600' }\n                },\n                grid: { display: false }\n            },\n            y: {\n                title: {\n                    display: true,\n                    text: 'Número de programas',\n                    font: { weight: '600' }\n                },\n                beginAtZero: true,\n                ticks: { stepSize: 2 }\n            }\n        },\n        plugins: {\n            legend: { display: false },\n            datalabels: {\n                anchor: 'end',\n                align: 'end',\n                color: '#000',\n                font: { weight: 'bold' },\n                formatter: (v) => v\n            }\n        },\n        animation: {\n            duration: 2200,\n            easing: 'easeOutBack'\n        }\n    },\n    plugins: [ChartDataLabels]\n});\n</script>\n</body>\n</html>",
  "allowScripts": true,
  "hotspots": []
}