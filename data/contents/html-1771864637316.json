  "title": "Estructura Orgánica",
  "type": "html",
  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Estructura Orgánica - Unitrópico</title>\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n\n  <style>\n    html,\n    body {\n      margin: 0;\n      padding: 0;\n      min-height: 100vh;\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n      font-family: 'Montserrat', sans-serif;\n      overflow-x: hidden;\n    }\n\n    /* Navbar (NO se toca estructura) */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n      position: sticky;\n      top: 0;\n      z-index: 1000;\n    }\n\n    .navbar-img img {\n      width: 100%;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal de la imagen */\n    .container {\n      width: 100%;\n      max-width: 1600px;\n      margin: 40px auto;\n      padding: 0 40px;\n      display: flex;\n      justify-content: center;\n      align-items: center;\n    }\n\n    .org-chart-wrapper {\n      width: 100%;\n      display: flex;\n      justify-content: center;\n    }\n\n    .org-chart-wrapper img {\n      width: 100%;\n      max-width: 1500px;\n      height: auto;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Responsive fino */\n    @media (max-width: 768px) {\n      .container {\n        padding: 0 15px;\n        margin: 25px auto;\n      }\n\n      .org-chart-wrapper img {\n        max-width: 100%;\n      }\n    }\n  </style>\n</head>\n\n<body>\n\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"container\">\n    <div class=\"org-chart-wrapper\">\n      <!-- PON AQUÍ TU IMAGEN -->\n      <img src=\"media/contexto_institucional/estructura_organica.png\" alt=\"Estructura Orgánica Unitrópico\">\n    </div>\n  </div>\n\n</body>\n</html>",
  "allowScripts": true,
  "hotspots": []
}