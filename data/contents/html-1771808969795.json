{
  "id": "html-1771808969795",
  "title": "Contenidos Curriculares",
  "type": "html",
  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Justificación - Oferta Internacional - Unitrópico</title>\n  <!-- Fuente Montserrat y CSS base -->\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n  <style>\n    /* =========================\n       ESTILOS ADICIONALES\n    ========================= */\n    html, body {\n      height: 100%;\n      margin: 0;\n      overflow-x: hidden;\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    /* Navbar */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n    }\n    .navbar-img img {\n      width: 100%;\n      height: auto;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal */\n    .container {\n      max-width: 1100px;\n      margin: auto;\n      padding: 0 25px;\n    }\n\n    /* Título del artículo (izquierda) */\n    .top-left-title {\n      margin-bottom: 20px;\n      color: var(--verde-1);\n    }\n\n    /* Encabezado de sección centrado con dos líneas */\n    .section-header-line {\n      margin-bottom: 40px;\n      text-align: center;\n    }\n    .section-header-line h2 {\n      font-size: 2.5rem;\n      font-weight: 700;\n      color: var(--verde-1);\n      margin: 0 0 15px 0;\n      line-height: 1.2;\n    }\n\n    /* Contenedor de las líneas (flex column para centrarlas) */\n    .lines-container {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 0px; /* espacio entre líneas */\n    }\n\n    /* Línea dorada (larga y delgada) */\n    .line-gold {\n      width: 300px;\n      height: 3px;\n      background-color: var(--bronce-1);\n      border-radius: 2px;\n    }\n\n    /* Línea gris (más corta y más alta) */\n    .line-gray {\n      width: 150px;\n      height: 6px;\n      background-color: #A0A0A0; /* gris suave, puedes cambiarlo por --bronce-4 si prefieres */\n      border-radius: 3px;\n    }\n\n    /* --- Estilos para los Árboles Pequeños (Praxis, Integral, Electivas) --- */\n    .trees-container {\n      display: flex;\n      justify-content: center;\n      align-items: flex-end;\n      gap: 30px;\n      margin-top: 40px;\n      margin-bottom: 50px;\n      width: 100%;\n      flex-wrap: wrap; /* Permitir que bajen en móviles */\n    }\n\n    .small-tree {\n      display: flex;\n      justify-content: center;\n    }\n\n    .small-tree ul {\n      padding-top: 20px; \n      position: relative;\n      display: flex;\n      justify-content: center;\n      padding-left: 0;\n      margin: 0;\n    }\n\n    .small-tree li {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      list-style-type: none;\n      position: relative;\n      padding: 20px 15px 0 15px;\n    }\n\n    /* Conectores horizontales superiores */\n    .small-tree li::before, .small-tree li::after {\n      content: '';\n      position: absolute; \n      top: 0; \n      right: 50%;\n      border-top: 2px solid #5A8AC6;\n      width: 50%; \n      height: 20px;\n    }\n    .small-tree li::after {\n      right: auto; \n      left: 50%;\n      border-left: 2px solid #5A8AC6;\n    }\n\n    /* Raiz */\n    .small-tree li:only-child::after, .small-tree li:only-child::before {\n      display: none;\n    }\n    .small-tree li:only-child { padding-top: 0; }\n\n    /* Puntas */\n    .small-tree li:first-child::before, .small-tree li:last-child::after {\n      border: 0 none;\n    }\n    .small-tree li:last-child::before {\n      border-right: 2px solid #5A8AC6;\n    }\n    \n    /* Conector vertical bajando del padre */\n    .small-tree ul ul::before {\n      content: '';\n      position: absolute; \n      top: 0; \n      left: 50%;\n      border-left: 2px solid #5A8AC6;\n      width: 0; \n      height: 20px;\n      margin-left: -1px;\n    }\n\n    /* Nodos de los arboles pequeños */\n    .st-node {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      position: relative;\n      z-index: 2;\n    }\n    \n    .st-node-root { width: 140px; }\n    .st-node-child { width: 130px; } \n\n    .st-title {\n      width: 100%;\n      color: #FFFFFF;\n      text-align: center;\n      padding: 8px 6px;\n      font-weight: 700;\n      font-size: 0.8rem;\n      min-height: 50px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      line-height: 1.2;\n    }\n\n    .st-subtitle {\n      background-color: #FFFFFF;\n      border: 1px solid #5A8AC6;\n      color: #333333;\n      padding: 2px 4px;\n      font-size: 0.65rem;\n      font-weight: 500;\n      margin-top: -8px;\n      z-index: 3;\n      position: relative;\n      white-space: nowrap;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n\n    /* Colores Específicos de los Nuevos Árboles */\n    .bg-st-praxis-root { background-color: #0088B4; }\n    .bg-st-praxis-c1 { background-color: #3366CC; }\n    .bg-st-praxis-c2 { background-color: #9999FF; }\n    .bg-st-praxis-c3 { background-color: #8C8CB8; }\n\n    .bg-st-integral-root { background-color: #9B2945; }\n    .bg-st-integral-c1 { background-color: #A35ECA; }\n    .bg-st-integral-c2 { background-color: #FF7575; }\n\n    .bg-st-eleccion-root { background-color: #B28B5C; } /* Color mostaza/dorado */\n    .bg-st-eleccion-c1 { background-color: #C09B66; }\n\n    .color-teal { color: var(--verde-1, #00563F); }\n    .color-gold { color: var(--bronce-1, #B29B5C); }\n    .color-arrow { color: #555555; margin: 0 2px; }\n    .color-gray { color: #555555; }\n    .color-blue-pct { color: #2A5BA1; font-weight: 700; } /* Porcentaje azul */\n    .color-gold-cred { color: #B29B5C; font-weight: 700; } /* Creditos dorado */\n\n    @media (max-width: 768px) {\n      .container {\n        margin: 15px;\n        padding: 0 15px;\n      }\n      .section-header-line h2 { font-size: 2rem; }\n      .line-gold { width: 200px; }\n      .line-gray { width: 100px; }\n      \n      .trees-container {\n        flex-direction: column;\n        align-items: center;\n        gap: 50px;\n      }\n    }\n  </style>\n</head>\n<body>\n  <!-- Navbar de imagen -->\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"container\">\n    <!-- Título del artículo (alineado izquierda) -->\n    <div class=\"top-left-title subtitulo text-verde-1\">\n      <span class=\"text-bronce-1\">Artículo 2.5.3.2.3.2.5.</span> Organización de actividades académicas y proceso formativo\n    </div>\n\n    <!-- Encabezado \"Estado de la Oferta Internacional\" centrado con dos líneas -->\n    <div class=\"section-header-line\">\n      \n      <h2><span style=\"margin:0px;\" class=\"text-verde-2   \">Contenidos </span>  Curriculares</h2>\n      <div class=\"lines-container\">\n        <div class=\"line-gold\"></div>\n        <div class=\"line-gray\"></div>\n      </div>\n    </div>\n\n    <!-- Contenedor Principal de Árboles Secundarios -->\n    <div class=\"trees-container\">\n      \n      <!-- Árbol 1: Praxis Investigativa (1 Raiz, 3 Hijos) -->\n      <div class=\"small-tree\">\n        <ul>\n          <li>\n            <!-- Raíz: Praxis -->\n            <div class=\"st-node st-node-root\">\n              <div class=\"st-title bg-st-praxis-root\">Praxis<br>Investigativa</div>\n              <div class=\"st-subtitle border-blue\">\n                 <span class=\"color-gold-cred\">14</span>&nbsp;<span class=\"color-gray\">créditos</span> <span class=\"color-arrow\">&rarr;</span> <span class=\"color-blue-pct\">9,5%</span>\n              </div>\n            </div>\n            <ul>\n              <li>\n                <div class=\"st-node st-node-child\">\n                  <div class=\"st-title bg-st-praxis-c1\">Fundamentos de<br>Investigación</div>\n                  <div class=\"st-subtitle border-blue\">\n                    <span class=\"color-gold-cred\">6</span>&nbsp;<span class=\"color-gray\">créditos</span> <span class=\"color-arrow\">&rarr;</span> <span class=\"color-blue-pct\">4,1%</span>\n                  </div>\n                </div>\n              </li>\n              <li>\n                <div class=\"st-node st-node-child\">\n                  <div class=\"st-title bg-st-praxis-c2\" style=\"font-size: 0.75rem;\">Praxis Investigativa<br>Específica</div>\n                  <div class=\"st-subtitle border-blue\">\n                    <span class=\"color-gold-cred\">4</span>&nbsp;<span class=\"color-gray\">créditos</span> <span class=\"color-arrow\">&rarr;</span> <span class=\"color-blue-pct\">2,7%</span>\n                  </div>\n                </div>\n              </li>\n              <li>\n                <div class=\"st-node st-node-child\">\n                  <div class=\"st-title bg-st-praxis-c3\">Trabajo de<br>Grado</div>\n                  <div class=\"st-subtitle border-blue\">\n                    <span class=\"color-gold-cred\">4</span>&nbsp;<span class=\"color-gray\">créditos</span> <span class=\"color-arrow\">&rarr;</span> <span class=\"color-blue-pct\">2,7%</span>\n                  </div>\n                </div>\n              </li>\n            </ul>\n          </li>\n        </ul>\n      </div>\n\n      <!-- Árbol 2: Formación Integral (1 Raiz, 2 Hijos) -->\n      <div class=\"small-tree\">\n        <ul>\n          <li>\n            <!-- Raíz: Formación Integral -->\n            <div class=\"st-node st-node-root\">\n              <div class=\"st-title bg-st-integral-root\">Formación<br>Integral</div>\n              <div class=\"st-subtitle border-blue\">\n                 <span class=\"color-gold-cred\">18</span>&nbsp;<span class=\"color-gray\">créditos</span> <span class=\"color-arrow\">&rarr;</span> <span class=\"color-blue-pct\">12,2%</span>\n              </div>\n            </div>\n            <ul>\n              <li>\n                <div class=\"st-node st-node-child\">\n                  <div class=\"st-title bg-st-integral-c1\">Competencias<br>Genéricas</div>\n                  <div class=\"st-subtitle border-blue\">\n                    <span class=\"color-gold-cred\">12</span>&nbsp;<span class=\"color-gray\">créditos</span> <span class=\"color-arrow\">&rarr;</span> <span class=\"color-blue-pct\">8,1%</span>\n                  </div>\n                </div>\n              </li>\n              <li>\n                <div class=\"st-node st-node-child\">\n                  <div class=\"st-title bg-st-integral-c2\">Identidad<br>Institucional</div>\n                  <div class=\"st-subtitle border-blue\">\n                    <span class=\"color-gold-cred\">6</span>&nbsp;<span class=\"color-gray\">créditos</span> <span class=\"color-arrow\">&rarr;</span> <span class=\"color-blue-pct\">4,1%</span>\n                  </div>\n                </div>\n              </li>\n            </ul>\n          </li>\n        </ul>\n      </div>\n\n      <!-- Árbol 3: Libre Elección (1 Raiz, 1 Hijo) -->\n      <div class=\"small-tree\">\n        <ul>\n          <li>\n            <!-- Raíz: Libre Elección -->\n            <div class=\"st-node st-node-root\" style=\"width: 120px;\">\n              <div class=\"st-title bg-st-eleccion-root\">Libre Elección</div>\n              <div class=\"st-subtitle border-blue\">\n                 <span class=\"color-gold-cred\">13</span>&nbsp;<span class=\"color-gray\">créditos</span> <span class=\"color-arrow\">&rarr;</span> <span class=\"color-blue-pct\">8,8%</span>\n              </div>\n            </div>\n            <ul>\n              <li>\n                <div class=\"st-node st-node-child\" style=\"width: 120px;\">\n                  <div class=\"st-title bg-st-eleccion-c1\">Agrupación<br>Única</div>\n                  <div class=\"st-subtitle border-blue\">\n                    <span class=\"color-gold-cred\">13</span>&nbsp;<span class=\"color-gray\">créditos</span> <span class=\"color-arrow\">&rarr;</span> <span class=\"color-blue-pct\">8,8%</span>\n                  </div>\n                </div>\n              </li>\n            </ul>\n          </li>\n        </ul>\n      </div>\n\n    </div>\n  </div>\n\n  <!-- Badge Vigilada MinEducación (comentado) -->\n  <!-- <div class=\"vigilada\">– Vigilada MinEducación –</div> -->\n</body>\n</html>",
  "allowScripts": true,
  "hotspots": []
}