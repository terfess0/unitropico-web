{
  "id": "html-agenda",
  "title": "Agenda del Programa",
  "type": "html",
  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Agenda de Visita - Unitrópico</title>\n  <!-- Fuente Montserrat y CSS base -->\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n  <style>\n    /* =========================\n       ESTILOS ADICIONALES\n    ========================= */\n    html,\n    body {\n      height: 100%;\n      margin: 0;\n      overflow-x: hidden;\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    /* Navbar */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n    }\n\n    .navbar-img img {\n      width: 100%;\n      height: auto;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal */\n    .container {\n      max-width: 1100px;\n      margin: 10px auto;\n      padding: 0 25px;\n    }\n\n    /* Título del artículo (izquierda) */\n    .top-left-title {\n      margin-bottom: 20px;\n      color: var(--verde-1);\n    }\n\n    /* Encabezado de sección centrado con dos líneas */\n    .section-header-line {\n      margin-bottom: 40px;\n      text-align: center;\n    }\n\n    .section-header-line h2 {\n      font-size: 2.5rem;\n      font-weight: 700;\n      color: var(--verde-1);\n      margin: 0 0 0px 0;\n      line-height: 1.2;\n    }\n\n    /* Contenedor de las líneas (flex column para centrarlas) */\n    .lines-container {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 0px;\n      /* espacio entre líneas */\n    }\n\n    /* Línea dorada (larga y delgada) */\n    .line-gold {\n      width: 300px;\n      height: 3px;\n      background-color: var(--bronce-1);\n      border-radius: 2px;\n    }\n\n    /* Línea gris (más corta y más alta) */\n    .line-gray {\n      width: 150px;\n      height: 6px;\n      background-color: #A0A0A0;\n      /* gris suave */\n      border-radius: 3px;\n    }\n\n    /* Contenedor de encabezados de día */\n    .days-header-wrapper {\n      display: flex;\n      justify-content: space-around;\n      margin-bottom: 25px;\n    }\n\n    .day-box {\n      padding: 10px 30px;\n      font-weight: 700;\n      font-size: 1.2rem;\n      color: var(--bronce-1);\n      background: rgba(255, 255, 255, 0.7);\n      transition: all 0.3s ease;\n    }\n\n    .day-box.day-1 {\n      border: 1px dashed var(--bronce-1);\n    }\n\n    .day-box.day-2 {\n      border: 1px solid var(--bronce-2);\n    }\n\n    /* Gran caja de agenda (Borde Verde) */\n    .agenda-grid-container {\n      background: rgba(255, 255, 255, 0.85);\n      backdrop-filter: blur(8px);\n      border: 1px solid #3B7782;\n      display: grid;\n      grid-template-columns: 1fr 1px 1fr;\n      position: relative;\n      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);\n      border-radius: 4px;\n      overflow: hidden;\n      animation: fadeInUp 1s ease-out;\n    }\n\n    .v-line {\n      background-color: #3B7782;\n      height: 100%;\n    }\n\n    .agenda-side {\n      padding: 15px 10px;\n    }\n\n    /* Filas de la agenda */\n    .agenda-row {\n      display: grid;\n      grid-template-columns: 100px 20px 1fr;\n      align-items: center;\n      padding: 4px 15px;\n      font-size: 0.95rem;\n      color: #1a1a1a;\n      transition: all 0.2s ease;\n    }\n\n    .agenda-row:hover {\n      background: rgba(0, 89, 78, 0.05);\n      transform: scale(1.01);\n    }\n\n    .item-time {\n      font-weight: 400;\n      color: #333;\n      white-space: nowrap;\n    }\n\n    .item-sep {\n      text-align: center;\n      color: #333;\n    }\n\n    .item-desc {\n      font-weight: 500;\n      padding-left: 10px;\n    }\n\n    /* Animaciones */\n    @keyframes fadeInUp {\n      from {\n        opacity: 0;\n        transform: translateY(30px);\n      }\n\n      to {\n        opacity: 1;\n        transform: translateY(0);\n      }\n    }\n\n    /* Responsive */\n    @media (max-width: 900px) {\n      .agenda-grid-container {\n        grid-template-columns: 1fr;\n      }\n\n      .v-line {\n        display: none;\n      }\n\n      .days-header-wrapper {\n        flex-direction: column;\n        align-items: center;\n        gap: 15px;\n      }\n\n      .agenda-row {\n        grid-template-columns: 120px 20px 1fr;\n        font-size: 0.85rem;\n      }\n    }\n  </style>\n</head>\n\n<body>\n\n  <!-- Navbar de imagen -->\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"container\">\n\n    <!-- Encabezado Agenda centrado con las dos líneas solicitadas -->\n    <div class=\"section-header-line\">\n      <h2 class=\"titulo text-verde-1\">Agenda</h2>\n      <div class=\"lines-container\">\n        <div class=\"line-gold\"></div>\n        <div class=\"line-gray\"></div>\n      </div>\n    </div>\n\n    <!-- Encabezados de Día -->\n    <div class=\"days-header-wrapper\">\n      <div class=\"day-box day-1\">Día 1 – 12 marzo 2026</div>\n      <div class=\"day-box day-2\">Día 2 – 13 marzo 2026</div>\n    </div>\n\n    <!-- Red de la Agenda con borde verdoso -->\n    <div class=\"agenda-grid-container\">\n\n      <!-- Lado Día 1 -->\n      <div class=\"agenda-side\">\n        <div class=\"agenda-row\">\n          <div class=\"item-time\">8:00 - 8:30</div>\n          <div class=\"item-sep\">am</div>\n          <div class=\"item-desc\">Presentación Contexto Institucional</div>\n        </div>\n        <div class=\"agenda-row\">\n          <div class=\"item-time\">8:30 - 10:30</div>\n          <div class=\"item-sep\">am</div>\n          <div class=\"item-desc\">Condición 1, 2 y 3</div>\n        </div>\n        <div class=\"agenda-row\">\n          <div class=\"item-time\">10:30 - 10:50</div>\n          <div class=\"item-sep\">am</div>\n          <div class=\"item-desc\">Receso</div>\n        </div>\n        <div class=\"agenda-row\">\n          <div class=\"item-time\">10:50 - 12:30</div>\n          <div class=\"item-sep\">pm</div>\n          <div class=\"item-desc\">Condición 4 y 5</div>\n        </div>\n        <div class=\"agenda-row\">\n          <div class=\"item-time\">12:30 - 2:30</div>\n          <div class=\"item-sep\">pm</div>\n          <div class=\"item-desc\">Almuerzo</div>\n        </div>\n        <div class=\"agenda-row\">\n          <div class=\"item-time\">2:30 - 4:30</div>\n          <div class=\"item-sep\">pm</div>\n          <div class=\"item-desc\">Condición 6 y 7</div>\n        </div>\n        <div class=\"agenda-row\">\n          <div class=\"item-time\">4:30 - 4:50</div>\n          <div class=\"item-sep\">pm</div>\n          <div class=\"item-desc\">Receso</div>\n        </div>\n        <div class=\"agenda-row\">\n          <div class=\"item-time\">4:50 - 5:30</div>\n          <div class=\"item-sep\">pm</div>\n          <div class=\"item-desc\">Condición 8</div>\n        </div>\n      </div>\n\n      <!-- Separador Central -->\n      <div class=\"v-line\"></div>\n\n      <!-- Lado Día 2 -->\n      <div class=\"agenda-side\">\n        <div class=\"agenda-row\">\n          <div class=\"item-time\">8:00 - 9:00</div>\n          <div class=\"item-sep\">am</div>\n          <div class=\"item-desc\">Condición 9</div>\n        </div>\n        <div class=\"agenda-row\">\n          <div class=\"item-time\">9:00 - 9:30</div>\n          <div class=\"item-sep\">am</div>\n          <div class=\"item-desc\">Recorrido institucional (virtual)</div>\n        </div>\n        <div class=\"agenda-row\">\n          <div class=\"item-time\">9:30 - 10:00</div>\n          <div class=\"item-sep\">am</div>\n          <div class=\"item-desc\">Receso</div>\n        </div>\n        <div class=\"agenda-row\">\n          <div class=\"item-time\">10:00 - 10:30</div>\n          <div class=\"item-sep\">am</div>\n          <div class=\"item-desc\">Reunión con Profesores</div>\n        </div>\n        <div class=\"agenda-row\">\n          <div class=\"item-time\">10:30 - 11:00</div>\n          <div class=\"item-sep\">am</div>\n          <div class=\"item-desc\">Reunión con Estudiantes</div>\n        </div>\n        <div class=\"agenda-row\">\n          <div class=\"item-time\">11:00 - 11:30</div>\n          <div class=\"item-sep\">am</div>\n          <div class=\"item-desc\">Reunión con Egresados facultad</div>\n        </div>\n        <div class=\"agenda-row\">\n          <div class=\"item-time\">11:30 - 12:00</div>\n          <div class=\"item-sep\">pm</div>\n          <div class=\"item-desc\">Reunión con Sector productivo</div>\n        </div>\n        <div class=\"agenda-row\">\n          <div class=\"item-time\">12:00 - 12:30</div>\n          <div class=\"item-sep\">pm</div>\n          <div class=\"item-desc\">Cierre de visita</div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n</body>\n\n</html>",
  "allowScripts": true,
  "hotspots": []
}