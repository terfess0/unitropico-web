{
  "id": "html-1771885551479",
  "title": "Componentes Formativos",
  "type": "html",
  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Justificación - Oferta Internacional - Unitrópico</title>\n  <!-- Fuente Montserrat y CSS base -->\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n  <style>\n    /* =========================\n       ESTILOS ADICIONALES\n    ========================= */\n    html,\n    body {\n      height: 100%;\n      margin: 0;\n      overflow-x: hidden;\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    /* Navbar */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n    }\n\n    .navbar-img img {\n      width: 100%;\n      height: auto;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal */\n    .container {\n      max-width: 1100px;\n      margin: 30px auto;\n      padding: 0 25px;\n    }\n\n    /* Estilos para Estrategias de flexibilización */\n    .section-header-line {\n      margin-bottom: 40px;\n      text-align: center;\n      padding-top: 10px;\n    }\n\n    .section-header-line h2 {\n      font-weight: 400;\n      font-size: 2.2rem;\n      line-height: 1.35;\n      color: #007580;\n      margin: 0 0 10px 0;\n    }\n\n    /* Estilos del Mapa Conceptual (Perfil de Egreso) */\n    .mindmap-viewport {\n      width: 100%;\n      height: 680px;\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      position: relative;\n      margin-bottom: 50px;\n      overflow: visible;\n    }\n\n    .mindmap-container {\n      position: relative;\n      width: 800px;\n      height: 600px;\n    }\n\n    .mindmap-node {\n      position: absolute;\n      border-radius: 50%;\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      text-align: center;\n      color: #fff;\n      padding: 20px;\n      box-sizing: border-box;\n      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);\n    }\n\n    /* Nodo Central */\n    .node-center {\n      width: 160px;\n      height: 160px;\n      background-color: #837473;\n      /* Gris Pardo */\n      font-size: 1.15rem;\n      font-weight: 700;\n      top: 50%;\n      left: 50%;\n      transform: translate(-50%, -50%);\n      z-index: 10;\n    }\n\n    /* Nodos satélite circulantes */\n    .node-sat {\n      width: 210px;\n      height: 210px;\n      padding: 10px;\n      font-size: 0.92rem;\n      line-height: 1.25;\n      transform: translate(-50%, -50%);\n    }\n\n    .node-sat strong {\n      font-weight: 700;\n    }\n\n    /* Posicionamiento satélites (aprox ángulos) */\n    .top-center {\n      top: 12%;\n      left: 50%;\n      background-color: #ba9b5e;\n    }\n\n    /* dorado oscuro */\n    .top-right {\n      top: 32%;\n      left: 82%;\n      background-color: #2b776a;\n    }\n\n    /* verde oscuro */\n    .bottom-right {\n      top: 72%;\n      left: 82%;\n      background-color: #ab8e4e;\n    }\n\n    /* oro tierra */\n    .bottom-center {\n      top: 86%;\n      left: 50%;\n      background-color: #1a5c53;\n    }\n\n    /* verde más oscuro */\n    .bottom-left {\n      top: 72%;\n      left: 18%;\n      background-color: #b5954a;\n    }\n\n    /* oro mostaza */\n    .top-left {\n      top: 32%;\n      left: 18%;\n      background-color: #3b7b6c;\n    }\n\n    /* verde base */\n\n    /* Punteros visuales a textos flotantes */\n    .schema-text-float {\n      position: absolute;\n      font-size: 0.85rem;\n      color: #007580;\n      max-width: 160px;\n      line-height: 1.3;\n    }\n\n    .txt-tr {\n      top: 20%;\n      left: 100%;\n    }\n\n    .txt-mr {\n      top: 65%;\n      left: 100%;\n      transform: translateY(-50%);\n    }\n\n    .txt-br {\n      top: 92%;\n      left: 75%;\n    }\n\n    .txt-ml {\n      top: 65%;\n      right: 100%;\n      text-align: right;\n    }\n\n    /* Flechas conectoras hacia el centro (usando css limits) */\n    .connector {\n      position: absolute;\n      top: 50%;\n      left: 50%;\n      width: 20px;\n      height: 26px;\n      background: #aec3d6;\n      clip-path: polygon(50% 0%, 0% 100%, 100% 100%);\n      transform-origin: 50% 115px;\n      margin-left: -10px;\n      margin-top: -115px;\n      z-index: 5;\n    }\n\n    .c-1 {\n      transform: rotate(0deg);\n    }\n\n    .c-2 {\n      transform: rotate(60deg);\n    }\n\n    .c-3 {\n      transform: rotate(120deg);\n    }\n\n    .c-4 {\n      transform: rotate(180deg);\n    }\n\n    .c-5 {\n      transform: rotate(240deg);\n    }\n\n    .c-6 {\n      transform: rotate(300deg);\n    }\n\n    /* Responsive */\n    @media (max-width: 900px) {\n      .mindmap-viewport {\n        transform: scale(0.65);\n      }\n    }\n\n    @media (max-width: 768px) {\n      .container {\n        margin: 15px;\n        padding: 0 15px;\n      }\n\n      .mindmap-viewport {\n        transform: scale(0.45);\n        height: 450px;\n      }\n\n      .section-header-line h2 {\n        font-size: 1.5rem !important;\n      }\n\n      .line-gold {\n        width: 100% !important;\n        max-width: 550px;\n      }\n\n      .line-gray {\n        width: 80% !important;\n        max-width: 450px;\n      }\n    }\n  </style>\n</head>\n\n<body>\n  <!-- Navbar de imagen -->\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"container\">\n    <!-- Título del artículo (alineado izquierda) -->\n    <div class=\"top-left-title subtitulo text-verde-1\">\n      <span class=\"text-bronce-1\">Artículo 2.5.3.2.3.2.4.</span> Aspectos curriculares - a) Componentes formativos\n    </div>\n\n    <!-- Encabezado centrado -->\n    <div class=\"section-header-line\" style=\"margin-bottom: 50px;\">\n      <h2>\n        <strong style=\"color: #007580; font-weight: 700;\">Componentes Formativos</strong>\n      </h2>\n      <div style=\"display: flex; flex-direction: column; align-items: center; gap: 0px;\">\n        <div class=\"line-gold\" style=\"width: 550px; height: 3px; background-color: #ba9b5e; border-radius: 2px;\"></div>\n        <div class=\"line-gray\" style=\"width: 450px; height: 6px; background-color: #e0e0e0; border-radius: 3px;\"></div>\n      </div>\n    </div>\n\n    <!-- Contenido: Mapa Conceptual -->\n    <div class=\"mindmap-viewport\">\n      <div class=\"mindmap-container\">\n\n        <!-- Flechas al centro -->\n        <div class=\"connector c-1\"></div>\n        <div class=\"connector c-2\"></div>\n        <div class=\"connector c-3\"></div>\n        <div class=\"connector c-4\"></div>\n        <div class=\"connector c-5\"></div>\n        <div class=\"connector c-6\"></div>\n\n        <!-- Centro -->\n        <div class=\"mindmap-node node-center\">\n          Ingeniero<br>en<br>Inteligencia<br>Artificial\n        </div>\n\n        <!-- Satélites -->\n        <div class=\"mindmap-node node-sat top-center\">\n          Profesional con<br>sólida formación<br>científica, pensamiento<br>crítico e\n          iniciativa<br>innovadora\n        </div>\n        <div class=\"mindmap-node node-sat top-right\">\n          Examina los<br>problemas<br>sociales y<br>ambientales\n        </div>\n        <div class=\"mindmap-node node-sat bottom-right\">\n          Domina los<br>fundamentos<br>lógicos, matemáticos,<br>estadísticos, físicos<br>e informáticos\n          para<br>formular y liderar<br>proyectos\n        </div>\n        <div class=\"mindmap-node node-sat bottom-center\">\n          Capaz de diseñar<br>soluciones<br>inteligentes\n        </div>\n        <div class=\"mindmap-node node-sat bottom-left\">\n          Se desempeña<br>con<br>responsabilidad y<br>ética en entornos<br>interdisciplinarios\n        </div>\n        <div class=\"mindmap-node node-sat top-left\">\n          Genera impacto<br>en sectores<br>estratégicos<br>como la<br>industria, la<br>agricultura,\n          la<br>energía, la<br>educación y la<br>salud\n        </div>\n\n        <!-- Textos Extras flotantes -->\n        <div class=\"schema-text-float txt-tr\">\n          Holística,<br>Solidaria y<br>Bioética\n        </div>\n        <div class=\"schema-text-float txt-mr\">\n          Investigación y<br>Desarrollo Tecnológico<br>e Innovación\n        </div>\n        <div class=\"schema-text-float txt-br\">\n          Diseño experimental,<br>Selección de Hardware y Arquitecturas IoT,<br>Protección de Datos y<br>Desarrollo,\n          entrenamiento y despliegue de modelos de Machine Learning y Deep Learning\n        </div>\n        <div class=\"schema-text-float txt-ml\">\n          Integrando tecnologías de vanguardia en ámbitos como la sostenibilidad ambiental y las ciudades inteligentes\n        </div>\n\n      </div>\n    </div>",
  "allowScripts": true,
  "hotspots": []
}