  "type": "html",
  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Justificación - Oferta Internacional - Unitrópico</title>\n  <!-- Fuente Montserrat y CSS base -->\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n  <style>\n    /* =========================\n       ESTILOS ADICIONALES\n    ========================= */\n    html,\n    body {\n      height: 100%;\n      margin: 0;\n      overflow-x: hidden;\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    /* Navbar */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n    }\n\n    .navbar-img img {\n      width: 100%;\n      height: auto;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal */\n    .container {\n      max-width: 1100px;\n      margin: 30px auto;\n      padding: 0 25px;\n    }\n\n    /* Estilos para Estrategias de flexibilización */\n    .section-header-line {\n      margin-bottom: 40px;\n      text-align: center;\n      padding-top: 10px;\n    }\n\n    .section-header-line h2 {\n      font-weight: 400;\n      font-size: 2.2rem;\n      line-height: 1.35;\n      color: #007580;\n      margin: 0 0 10px 0;\n    }\n\n    /* Estilos del diagrama Competencias / RAE */\n    .schema-container {\n      width: 100%;\n      max-width: 1100px;\n      margin: 40px auto;\n      display: flex;\n      flex-direction: column;\n      gap: 20px;\n    }\n\n    .schema-row-header {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      margin-bottom: 5px;\n    }\n\n    .schema-header-box {\n      border: 2px solid #002244;\n      border-radius: 6px;\n      background-color: transparent;\n      color: #000;\n      font-weight: 700;\n      text-align: center;\n      padding: 5px 10px;\n      font-size: 1.05rem;\n      flex-shrink: 0;\n    }\n\n    .schema-row {\n      display: flex;\n      align-items: stretch;\n      justify-content: space-between;\n    }\n\n    .schema-box {\n      border-radius: 12px;\n      color: #ffffff;\n      display: flex;\n      flex-direction: column;\n      justify-content: center;\n      font-size: 0.95rem;\n      box-sizing: border-box;\n    }\n\n    .bg-yellow {\n      background-color: #cbb471;\n      font-weight: 700;\n      font-size: 1.15rem;\n      text-align: center;\n      align-items: center;\n      padding: 20px;\n    }\n\n    .bg-green {\n      background-color: #3b7b6c;\n      text-align: justify;\n      line-height: 1.4;\n      padding: 25px 30px;\n    }\n\n    .bg-dark-yellow {\n      background-color: #bc9c5f;\n      text-align: center;\n      line-height: 1.4;\n      padding: 25px;\n    }\n\n    .schema-arrow-col {\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n\n    /* Flechas dibujadas con CSS */\n    .schema-arrow {\n      display: inline-flex;\n      align-items: center;\n    }\n\n    .schema-arrow::before {\n      content: '';\n      display: block;\n      width: 18px;\n      height: 16px;\n      background-color: #aec3d6;\n    }\n\n    .schema-arrow::after {\n      content: '';\n      display: block;\n      width: 0;\n      height: 0;\n      border-top: 18px solid transparent;\n      border-bottom: 18px solid transparent;\n      border-left: 20px solid #aec3d6;\n    }\n\n    .w-col-1 {\n      width: 17%;\n    }\n\n    .w-col-2 {\n      width: 5%;\n    }\n\n    .w-col-3 {\n      width: 43%;\n    }\n\n    .w-col-4 {\n      width: 5%;\n    }\n\n    .w-col-5 {\n      width: 30%;\n    }\n\n    /* Clases adicionales para anidamiento del diseño Especificas de Facultad */\n    .schema-inner-row {\n      display: flex;\n      align-items: stretch;\n      justify-content: space-between;\n      width: 100%;\n    }\n\n    .w-in-2 {\n      width: 6%;\n    }\n\n    .w-in-3 {\n      width: 52%;\n    }\n\n    .w-in-4 {\n      width: 6%;\n    }\n\n    .w-in-5 {\n      width: 36%;\n    }\n\n    /* Responsive */\n    @media (max-width: 900px) {\n\n      .schema-row,\n      .schema-inner-row,\n      .schema-row-header {\n        flex-direction: column;\n        align-items: center;\n      }\n\n      .schema-row>div:nth-child(2) {\n        width: 100% !important;\n      }\n\n      .w-col-1,\n      .w-col-2,\n      .w-col-3,\n      .w-col-4,\n      .w-col-5,\n      .w-in-2,\n      .w-in-3,\n      .w-in-4,\n      .w-in-5 {\n        width: 100% !important;\n        margin-bottom: 15px;\n      }\n\n      .schema-arrow {\n        transform: rotate(90deg);\n        margin: 10px 0;\n      }\n\n      .schema-row-header {\n        display: none;\n      }\n\n      /* Ocultar cabeceras en celular y depender del contexto */\n    }\n\n    @media (max-width: 768px) {\n      .container {\n        margin: 15px;\n        padding: 0 15px;\n      }\n\n      .section-header-line h2 {\n        font-size: 1.5rem !important;\n      }\n\n      .line-gold {\n        width: 100% !important;\n        max-width: 550px;\n      }\n\n      .line-gray {\n        width: 80% !important;\n        max-width: 450px;\n      }\n    }\n  </style>\n</head>\n\n<body>\n  <!-- Navbar de imagen -->\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"container\">\n    <!-- Título del artículo (alineado izquierda) -->\n    <div class=\"top-left-title subtitulo text-verde-1\">\n      <span class=\"text-bronce-1\">Artículo 2.5.3.2.3.2.4.</span> Aspectos curriculares - a) Componentes formativos\n    </div>\n\n    <!-- Encabezado centrado -->\n    <div class=\"section-header-line\" style=\"margin-bottom: 50px;\">\n      <h2>\n        <strong style=\"color: #007580; font-weight: 700;\">Competencias</strong>\n      </h2>\n      <div style=\"display: flex; flex-direction: column; align-items: center; gap: 0px;\">\n        <div class=\"line-gold\" style=\"width: 550px; height: 3px; background-color: #ba9b5e; border-radius: 2px;\"></div>\n        <div class=\"line-gray\" style=\"width: 450px; height: 6px; background-color: #e0e0e0; border-radius: 3px;\"></div>\n      </div>\n    </div>\n\n    <!-- Contenido: Esquema de Competencias -->\n    <div class=\"schema-container\">\n\n      <!-- Fila de Cabeceras -->\n      <div class=\"schema-row-header\">\n        <div class=\"schema-header-box w-col-1\" style=\"background: white;\">Tipo</div>\n        <div class=\"w-col-2\"></div>\n        <div class=\"schema-header-box w-col-3\" style=\"background: white;\">Competencia</div>\n        <div class=\"w-col-4\"></div>\n        <div class=\"schema-header-box w-col-5\" style=\"background: white;\">RAE</div>\n      </div>\n\n      <!-- Esquema Unificado: Específicas de Facultad -->\n      <div class=\"schema-row\">\n        <!-- Columna Izquierda Única -->\n        <div class=\"schema-box bg-yellow w-col-1\" style=\"justify-content: center; font-size: 1.15rem;\">\n          Especificas de <br>Programa\n        </div>\n\n        <!-- Grupo contenedor de Sub-filas derechas -->\n        <div style=\"display: flex; flex-direction: column; gap: 20px; width: 81%; justify-content: space-between;\">\n\n          <!-- Sub-fila 1 -->\n          <div class=\"schema-inner-row\">\n            <div class=\"schema-arrow-col w-in-2\">\n              <div class=\"schema-arrow\"></div>\n            </div>\n            <div class=\"schema-box bg-green w-in-3\">\n              <span>Dominar los fundamentos matemáticos, estadísticos, computacionales y físicos para diseñar, entrenar y evaluar modelos de Machine Learning y Deep Learning</span>\n            </div>\n            <div class=\"schema-arrow-col w-in-4\">\n              <div class=\"schema-arrow\"></div>\n            </div>\n            <div class=\"schema-box bg-dark-yellow w-in-5\">\n              Formula modelos de IA a partir de la generación y el análisis de datos reales, aplicando criterios de precisión, eficiencia y adecuación tecnológica\n            </div>\n          </div>\n\n          <!-- Sub-fila 2 -->\n          <div class=\"schema-inner-row\">\n            <div class=\"schema-arrow-col w-in-2\">\n              <div class=\"schema-arrow\"></div>\n            </div>\n            <div class=\"schema-box bg-green w-in-3\">\n              <span>Integrar arquitecturas IoT, mecanismos de protección de datos, ética en la IA y soluciones inteligentes que respondan a los desafíos de sectores estratégicos\n</span>\n            </div>\n            <div class=\"schema-arrow-col w-in-4\">\n              <div class=\"schema-arrow\"></div>\n            </div>\n            <div class=\"schema-box bg-dark-yellow w-in-5\">\n              Diseña soluciones inteligentes que combinan dispositivos IoT, algoritmos de IA y técnicas de ciberseguridad, respondiendo a problemas específicos de sectores como salud, agricultura o energía\n\n            </div>\n          </div>\n\n        </div>\n      </div>\n\n    </div>\n\n  </div>\n</body>\n\n</html>",
  "allowScripts": true,
  "hotspots": []
}