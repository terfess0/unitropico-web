{
  "id": "html-1771912945476",
  "title": "Seguimiento sistemático a los RAE",
  "type": "html",
  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Justificación - Oferta Internacional - Unitrópico</title>\n  <!-- Fuente Montserrat y CSS base -->\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n  <style>\n    /* =========================\n       ESTILOS ADICIONALES\n    ========================= */\n    html,\n    body {\n      height: 100%;\n      margin: 0;\n      overflow-x: hidden;\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    /* Navbar */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n    }\n\n    .navbar-img img {\n      width: 100%;\n      height: auto;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal */\n    .container {\n      max-width: 1100px;\n      margin: 30px auto;\n      padding: 0 25px;\n    }\n\n    /* Estilos para Estrategias de flexibilización */\n    .section-header-line {\n      margin-bottom: 40px;\n      text-align: center;\n      padding-top: 10px;\n    }\n\n    .section-header-line h2 {\n      font-weight: 400;\n      font-size: 2.2rem;\n      line-height: 1.35;\n      color: #007580;\n      margin: 0 0 10px 0;\n    }\n\n    /* Estilos para el Icono Lateral */\n    .comp-icon-row {\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      margin-top: 80px;\n      margin-bottom: 90px;\n      gap: 30px;\n    }\n\n    .comp-icon-container {\n      width: 140px;\n      height: 140px;\n      background-color: #fcfcfc;\n      border-radius: 50%;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08), inset 0 2px 10px rgba(0, 0, 0, 0.02);\n      border: 3px solid #f2f2f2;\n    }\n\n    .comp-icon-container img {\n      width: 55%;\n      height: auto;\n    }\n\n    .comp-text-title {\n      font-size: 2.2rem;\n      font-weight: 700;\n      color: #007580;\n    }\n\n    @media (max-width: 768px) {\n      .container {\n        margin: 15px;\n        padding: 0 15px;\n      }\n\n      .comp-icon-row {\n        flex-direction: column;\n        gap: 15px;\n      }\n\n      .comp-text-title {\n        font-size: 1.8rem;\n      }\n\n      .section-header-line h2 {\n        font-size: 1.5rem !important;\n      }\n\n      .line-gold {\n        width: 100% !important;\n        max-width: 550px;\n      }\n\n      .line-gray {\n        width: 80% !important;\n        max-width: 450px;\n      }\n    }\n\n    /* =========================================\n       NUEVO LAYOUT: SEGUIMIENTO SISTEMATICO RAE\n       ========================================= */\n    .rae-header {\n      margin-top: 50px;\n      margin-bottom: 50px;\n      text-align: center;\n    }\n\n    .rae-header h2 {\n      font-weight: 700;\n      font-size: 2.3rem;\n      color: #007580;\n      margin: 0 0 10px 0;\n    }\n\n    .rae-container {\n      position: relative;\n      width: 100%;\n      max-width: 1050px;\n      margin: 0 auto;\n      height: 600px;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    .rae-svg {\n      position: absolute;\n      top: 0; left: 0;\n      width: 100%; height: 100%;\n      z-index: 1;\n      pointer-events: none;\n    }\n\n    .rae-circle {\n      position: absolute;\n      border-radius: 50%;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n      color: white;\n      font-weight: 700;\n      line-height: 1.25;\n      box-shadow: 0 6px 15px rgba(0,0,0,0.15);\n      z-index: 5;\n      transform: translate(-50%, -50%);\n    }\n\n    .center-circle {\n      width: 160px;\n      height: 160px;\n      background-color: #89797d; /* grayish purple */\n      top: 300px;\n      left: 525px;\n      font-size: 0.95rem;\n      border: 4px solid white;\n    }\n\n    .btn-circle {\n      width: 140px;\n      height: 140px;\n      font-size: 1rem;\n      cursor: pointer;\n      transition: transform 0.2s, filter 0.2s;\n    }\n\n    .btn-circle:hover {\n      transform: translate(-50%, -50%) scale(1.05);\n      filter: brightness(1.1);\n    }\n\n    .top-circle {\n      background-color: #00594e;\n      top: 120px;\n      left: 525px;\n    }\n\n    .bl-circle {\n      background-color: #2b7d72; /* teal */\n      top: 450px;\n      left: 325px;\n    }\n\n    .br-circle {\n      background-color: #bfa773; /* gold */\n      top: 450px;\n      left: 725px;\n    }\n\n    /* Text boxes hidden initially */\n    .rae-text {\n      position: absolute;\n      background: white;\n      border: 2px solid #bfa773;\n      border-radius: 12px;\n      padding: 15px 20px;\n      color: #007580;\n      font-size: 0.9rem;\n      line-height: 1.4;\n      text-align: center;\n      box-sizing: border-box;\n      z-index: 10;\n      opacity: 0;\n      visibility: hidden;\n      transform: translateY(20px) scale(0.95);\n      transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1), transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.4s;\n      box-shadow: 0 4px 15px rgba(0,0,0,0.08);\n      pointer-events: none;\n    }\n\n    .rae-text.active {\n      opacity: 1;\n      visibility: visible;\n      transform: translateY(0) scale(1);\n    }\n\n    .text-box-1 {\n      top: 80px;\n      left: 630px;\n      width: 320px;\n    }\n\n    .text-box-2 {\n      top: 380px;\n      left: -75px;\n      width: 320px;\n    }\n\n    .text-box-3 {\n      top: 380px;\n      right: -100px;\n      width: 340px;\n    }\n\n    @media (max-width: 900px) {\n      .rae-container {\n        height: auto;\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        gap: 30px;\n        padding-bottom: 50px;\n      }\n      .rae-svg { display: none; }\n      .rae-circle {\n        position: static;\n        transform: none !important;\n      }\n      .rae-text {\n        position: static;\n        width: 90%;\n        max-width: 320px;\n      }\n      .rae-text.active {\n        display: block;\n      }\n    }\n  </style>\n</head>\n\n<body>\n  <!-- Navbar de imagen -->\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"container\">\n    <!-- Título del artículo (alineado izquierda) -->\n    <div class=\"top-left-title subtitulo text-verde-1\">\n      <span class=\"text-bronce-1\">2.5.3.2.3.2.4. Aspectos curriculares -</span> e) Mecanismos de Evaluación\n    </div>\n\n    <!-- Encabezado centrado -->\n    <div class=\"rae-header\">\n      <h2>Seguimiento sistemático a los RAE</h2>\n      <div style=\"display: flex; flex-direction: column; align-items: center; gap: 0px;\">\n        <div class=\"line-gold\" style=\"width: 450px; height: 3px; background-color: #ba9b5e; border-radius: 2px;\"></div>\n        <div class=\"line-gray\" style=\"width: 400px; height: 6px; background-color: #e0e0e0; border-radius: 3px;\"></div>\n      </div>\n    </div>\n\n    <!-- Contenedor Interactivo Graficos RAE -->\n    <div class=\"rae-container\" id=\"rae-container\">\n      \n      <svg class=\"rae-svg\" viewBox=\"0 0 1050 600\">\n        <line x1=\"525\" y1=\"300\" x2=\"525\" y2=\"120\" stroke=\"#4c779e\" stroke-width=\"3\" />\n        <line x1=\"525\" y1=\"300\" x2=\"325\" y2=\"450\" stroke=\"#4c779e\" stroke-width=\"3\" />\n        <line x1=\"525\" y1=\"300\" x2=\"725\" y2=\"450\" stroke=\"#4c779e\" stroke-width=\"3\" />\n      </svg>\n\n      <div class=\"rae-circle center-circle\">\n        Instrumentos<br>evaluación<br>por<br>observación<br>RAE\n      </div>\n\n      <!-- Top -->\n      <div class=\"rae-circle btn-circle top-circle\" onclick=\"toggleRaeText('rae-text-1')\">\n        Rúbrica\n      </div>\n      <div class=\"rae-text text-box-1\" id=\"rae-text-1\">\n        Una rúbrica señala con precisión la<br>actividad o producto que van a ser<br>evaluados\n      </div>\n\n      <!-- Bottom Left -->\n      <div class=\"rae-circle btn-circle bl-circle\" onclick=\"toggleRaeText('rae-text-2')\">\n        Participación<br>en clases\n      </div>\n      <div class=\"rae-text text-box-2\" id=\"rae-text-2\">\n        El profesor elabora un registro de la<br>frecuencia con que los estudiantes<br>aportan verbalmente ideas<br>relacionadas con el tema\n      </div>\n\n      <!-- Bottom Right -->\n      <div class=\"rae-circle btn-circle br-circle\" onclick=\"toggleRaeText('rae-text-3')\">\n        Demostración\n      </div>\n      <div class=\"rae-text text-box-3\" id=\"rae-text-3\">\n        Se le solicita al alumno que de manera<br>práctica muestre el manejo de un<br>instrumento, experimento o actividad<br>que requiera la secuencia de un<br>proceso o la manipulación de una<br>herramienta u objeto\n      </div>\n      \n    </div>\n\n  </div>\n\n  <!-- Script for interactions -->\n  <script>\n    function toggleRaeText(id) {\n      // En lugar de ocultar los demás, simplemente mostramos el objetivo (o lo alternamos)\n      const target = document.getElementById(id);\n      if (target) {\n        // Toggle the 'active' class to show the specific text box\n        target.classList.add('active');\n      }\n    }\n  </script>\n</body>\n\n</html>",
  "allowScripts": true,
  "hotspots": []
}