  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Justificación - Oferta Internacional - Unitrópico</title>\n  <!-- Fuente Montserrat y CSS base -->\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n  <style>\n    /* =========================\n       ESTILOS ADICIONALES\n    ========================= */\n    html,\n    body {\n      height: 100%;\n      margin: 0;\n      overflow-x: hidden;\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    /* Navbar */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n    }\n\n    .navbar-img img {\n      width: 100%;\n      height: auto;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal */\n    .container {\n      max-width: 1100px;\n      margin: 30px auto;\n      padding: 0 25px;\n    }\n\n    /* Estilos para Estrategias de flexibilización */\n    .section-header-line {\n      margin-bottom: 40px;\n      text-align: center;\n      padding-top: 10px;\n    }\n\n    .section-header-line h2 {\n      font-weight: 400;\n      font-size: 2.2rem;\n      line-height: 1.35;\n      color: #007580;\n      margin: 0 0 10px 0;\n    }\n\n    /* Estilos para el Icono Lateral */\n    .comp-icon-row {\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      margin-top: 80px;\n      margin-bottom: 90px;\n      gap: 30px;\n    }\n\n    .comp-icon-container {\n      width: 140px;\n      height: 140px;\n      background-color: #fcfcfc;\n      border-radius: 50%;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08), inset 0 2px 10px rgba(0, 0, 0, 0.02);\n      border: 3px solid #f2f2f2;\n    }\n\n    .comp-icon-container img {\n      width: 55%;\n      height: auto;\n    }\n\n    .comp-text-title {\n      font-size: 2.2rem;\n      font-weight: 700;\n      color: #007580;\n    }\n\n    @media (max-width: 768px) {\n      .container {\n        margin: 15px;\n        padding: 0 15px;\n      }\n\n      .comp-icon-row {\n        flex-direction: column;\n        gap: 15px;\n      }\n\n      .comp-text-title {\n        font-size: 1.8rem;\n      }\n\n      .section-header-line h2 {\n        font-size: 1.5rem !important;\n      }\n\n      .line-gold {\n        width: 100% !important;\n        max-width: 550px;\n      }\n\n      .line-gray {\n        width: 80% !important;\n        max-width: 450px;\n      }\n    }\n\n    \n\n    \n\n    /* =========================================\n       NUEVO LAYOUT: COMPONENTES DE INTERACCIÓN\n       ========================================= */\n    .interaccion-header {\n      margin-top: 50px;\n      margin-bottom: 20px;\n      text-align: center;\n    }\n\n    .interaccion-header h2 {\n      font-weight: 700;\n      font-size: 2.5rem;\n      color: #007580;\n      margin: 0 0 15px 0;\n    }\n  </style>\n</head>\n\n<body>\n  <!-- Navbar de imagen -->\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"container\">\n    <!-- Título del artículo (alineado izquierda) -->\n    <div class=\"top-left-title subtitulo text-verde-1\" style=\"margin-bottom: 50px;\">\n      <span class=\"text-bronce-1\">2.5.3.2.3.2.4. Aspectos curriculares -</span> d) Mecanismos de Evaluación\n\n    </div>\n\n    <!-- Encabezado centrado con doble línea -->\n    <div  class=\"interaccion-header\">\n      <h2>Mecanismos de Evaluación\n\n</h2>\n      <div style=\"display: flex; flex-direction: column; align-items: center; gap: 0px;\">\n        <div class=\"line-gold\" style=\"width: 480px; height: 3px; background-color: #ba9b5e; border-radius: 2px;\"></div>\n        <div class=\"line-gray\" style=\"width: 400px; height: 6px; background-color: #d1d1d1; border-radius: 3px;\"></div>\n      </div>\n    </div>\n\n  </div>\n</body>\n\n</html>",
