{
  "id": "html-1771807767283",
  "title": "Contenidos Curriculares",
  "type": "html",
  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Justificación - Oferta Internacional - Unitrópico</title>\n  <!-- Fuente Montserrat y CSS base -->\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n  <style>\n    /* =========================\n       ESTILOS ADICIONALES\n    ========================= */\n    html, body {\n      height: 100%;\n      margin: 0;\n      overflow-x: hidden;\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    /* Navbar */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n    }\n    .navbar-img img {\n      width: 100%;\n      height: auto;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal */\n    .container {\n      max-width: 1100px;\n      margin: auto;\n      padding: 0 25px;\n    }\n\n    /* Título del artículo (izquierda) */\n    .top-left-title {\n      margin-bottom: 20px;\n      color: var(--verde-1);\n    }\n\n    /* Encabezado de sección centrado con dos líneas */\n    .section-header-line {\n      margin-bottom: 40px;\n      text-align: center;\n    }\n    .section-header-line h2 {\n      font-size: 2.5rem;\n      font-weight: 700;\n      color: var(--verde-1);\n      margin: 0 0 15px 0;\n      line-height: 1.2;\n    }\n\n    /* Contenedor de las líneas (flex column para centrarlas) */\n    .lines-container {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 0px; /* espacio entre líneas */\n    }\n\n    /* Línea dorada (larga y delgada) */\n    .line-gold {\n      width: 300px;\n      height: 3px;\n      background-color: var(--bronce-1);\n      border-radius: 2px;\n    }\n\n    /* Línea gris (más corta y más alta) */\n    .line-gray {\n      width: 150px;\n      height: 6px;\n      background-color: #A0A0A0; /* gris suave, puedes cambiarlo por --bronce-4 si prefieres */\n      border-radius: 3px;\n    }\n\n    /* Grid de Asignaturas */\n    .courses-wrapper {\n      display: flex;\n      flex-direction: row;\n      margin-bottom: 50px;\n      width: 100%;\n      align-items: stretch;\n      gap: 15px;\n    }\n\n    .vertical-label {\n      writing-mode: vertical-rl;\n      transform: rotate(180deg);\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      padding: 15px 15px;\n      margin-right: 5px;\n      color: #FFFFFF;\n      font-weight: 700;\n      font-size: 1.15rem;\n      letter-spacing: 1px;\n    }\n\n    .courses-grid {\n      display: flex;\n      flex: 1;\n      gap: 15px;\n    }\n\n    .course-column {\n      flex: 1;\n      display: flex;\n      flex-direction: column;\n    }\n\n    .course-header {\n      display: flex;\n      align-items: center;\n      color: #FFFFFF;\n      font-weight: 700;\n      font-size: 1.05rem;\n      padding: 12px 15px;\n      min-height: 60px;\n      line-height: 1.2;\n    }\n\n    .square-white {\n      width: 14px;\n      height: 14px;\n      background-color: #FFFFFF;\n      margin-right: 12px;\n      flex-shrink: 0;\n    }\n\n    .course-list {\n      list-style: none;\n      padding: 0;\n      margin: 20px 0 0 0;\n      display: flex;\n      flex-direction: column;\n      gap: 15px;\n    }\n\n    .course-list li {\n      display: flex;\n      align-items: flex-start;\n      font-weight: 700;\n      font-size: 0.9rem;\n      line-height: 1.3;\n    }\n\n    .square-outline {\n      width: 16px;\n      height: 16px;\n      border: 3px solid #5A8AC6;\n      margin-right: 12px;\n      margin-top: 2px;\n      flex-shrink: 0;\n      background-color: transparent;\n    }\n\n    .bg-fundamentacion { background-color: #B2B424; }\n    .bg-matematicas { background-color: #A3BCA9; }\n    .bg-fisicas { background-color: #3A556A; }\n    .bg-fundamentos { background-color: #267963; }\n\n    .color-teal { color: var(--verde-1, #00563F); }\n    .color-gold { color: var(--bronce-1, #B29B5C); }\n\n    @media (max-width: 768px) {\n      .container {\n        margin: 15px;\n        padding: 0 15px;\n      }\n      .section-header-line h2 { font-size: 2rem; }\n      .line-gold { width: 200px; }\n      .line-gray { width: 100px; }\n      \n      .courses-wrapper {\n        flex-direction: column;\n        align-items: center;\n      }\n      .vertical-label {\n        writing-mode: horizontal-tb;\n        transform: rotate(0deg);\n        width: 100%;\n        margin-right: 0;\n        margin-bottom: 20px;\n        padding: 10px;\n      }\n      .courses-grid {\n        flex-direction: column;\n        width: 100%;\n        gap: 30px;\n      }\n    }\n  </style>\n</head>\n<body>\n  <!-- Navbar de imagen -->\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"container\">\n    <!-- Título del artículo (alineado izquierda) -->\n    <div class=\"top-left-title subtitulo text-verde-1\">\n      <span class=\"text-bronce-1\">Artículo 2.5.3.2.3.2.5.</span> Organización de actividades académicas y proceso formativo\n    </div>\n\n    <!-- Encabezado \"Estado de la Oferta Internacional\" centrado con dos líneas -->\n    <div class=\"section-header-line\">\n      \n      <h2><span style=\"margin:0px;\" class=\"text-verde-2   \">Contenidos </span>  Curriculares</h2>\n      <div class=\"lines-container\">\n        <div class=\"line-gold\"></div>\n        <div class=\"line-gray\"></div>\n      </div>\n    </div>\n\n    <!-- Grid de Asignaturas -->\n    <div class=\"courses-wrapper\">\n      \n      <!-- Etiqueta Lateral Vertical -->\n      <div class=\"vertical-label bg-fundamentacion\">\n        Fundamentación\n      </div>\n\n      <!-- Columnas de Asignaturas -->\n      <div class=\"courses-grid\">\n        \n        <!-- Columna 1: Matemáticas -->\n        <div class=\"course-column\">\n          <div class=\"course-header bg-matematicas\">\n            <span class=\"square-white\"></span>\n            Matemáticas\n          </div>\n          <ul class=\"course-list\">\n            <li class=\"color-teal\"><span class=\"square-outline\"></span>Algebra Lineal</li>\n            <li class=\"color-gold\"><span class=\"square-outline\"></span>Probabilidad y Estadística</li>\n            <li class=\"color-teal\"><span class=\"square-outline\"></span>Matemática Discretas</li>\n            <li class=\"color-gold\"><span class=\"square-outline\"></span>Diseño de Experimentos</li>\n            <li class=\"color-teal\"><span class=\"square-outline\"></span>Matemática Básica</li>\n            <li class=\"color-gold\"><span class=\"square-outline\"></span>Cálculo I</li>\n            <li class=\"color-teal\"><span class=\"square-outline\"></span>Cálculo II</li>\n            <li class=\"color-gold\"><span class=\"square-outline\"></span>Cálculo Multivariable</li>\n            <li class=\"color-teal\"><span class=\"square-outline\"></span>Ecuaciones Diferenciales</li>\n          </ul>\n        </div>\n\n        <!-- Columna 2: Físicas -->\n        <div class=\"course-column\">\n          <div class=\"course-header bg-fisicas\">\n            <span class=\"square-white\"></span>\n            Físicas\n          </div>\n          <ul class=\"course-list\">\n            <li class=\"color-teal\"><span class=\"square-outline\"></span>Física I</li>\n            <li class=\"color-gold\"><span class=\"square-outline\"></span>Física III</li>\n          </ul>\n        </div>\n\n        <!-- Columna 3: Fundamentos de Ingeniería -->\n        <div class=\"course-column\">\n          <div class=\"course-header bg-fundamentos\">\n            <span class=\"square-white\"></span>\n            <span>Fundamentos<br>de Ingeniería</span>\n          </div>\n          <ul class=\"course-list\">\n            <li class=\"color-teal\"><span class=\"square-outline\"></span>Introducción a la ingeniería</li>\n            <li class=\"color-gold\"><span class=\"square-outline\"></span>Algoritmos y computación</li>\n          </ul>\n        </div>\n\n      </div>\n    </div>\n  </div>\n\n  <!-- Badge Vigilada MinEducación (comentado) -->\n  <!-- <div class=\"vigilada\">– Vigilada MinEducación –</div> -->\n</body>\n</html>",
  "allowScripts": true,
  "hotspots": []
}