  "title": "Título",
  "type": "html",
  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Denominación del programa</title>\n\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n\n  <style>\n    html, body {\n      height: 100%;\n      margin: 0;\n      overflow-x: hidden;\n      /* Fondo general de la página: imagen que cubre todo, fija y centrada */\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n    }\n\n    /* Contenedor principal */\n    .hero {\n      position: relative;\n      min-height: 100vh;\n      display: flex;\n      align-items: center;\n      overflow: hidden;\n    }\n\n    /* Imagen izquierda con recorte diagonal y animación */\n    .hero-image {\n      position: absolute;\n      left: 0;\n      top: 0;\n      width: 52%;\n      height: 100%;\n      clip-path: polygon(0 0, 85% 0, 100% 50%, 85% 100%, 0 100%);\n      overflow: hidden;\n      pointer-events: none;\n    }\n\n    .hero-image::before {\n      content: \"\";\n      position: absolute;\n      inset: 0;\n      background: url(\"../img/lateral-7.webp\") no-repeat center left;\n      background-size: cover;\n      will-change: transform;\n      transform-origin: center;\n      animation: pulse-hero 6s ease-in-out infinite;\n      backface-visibility: hidden;\n      -webkit-backface-visibility: hidden;\n      transform: translateZ(0);\n    }\n\n    /* Panel derecho (texto) - sin fondo adicional, se ve el fondo del body */\n    .hero-content {\n      margin-left: 52%;\n      width: 48%;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      padding: 0 80px;\n    }\n\n    .hero-content h1 {\n      font-size: 52px;\n      font-weight: 800;\n      color: #0f5e57;\n      line-height: 1.15;\n    }\n\n    /* Badge superior derecho */\n    .top-badge {\n      position: absolute;\n      top: 40px;\n      right: 60px;\n      display: flex;\n      align-items: center;\n      gap: 15px;\n    }\n\n    .badge-year {\n      background: #B5A160;\n      color: white;\n      padding: 12px 22px;\n      font-weight: 800;\n      font-size: 20px;\n    }\n\n    .badge-text {\n      border-left: 3px solid #B5A160;\n      padding-left: 14px;\n      font-weight: 700;\n      color: #0f5e57;\n      font-size: 14px;\n      line-height: 1.2;\n    }\n\n    /* Logo inferior derecho */\n    .logo-bottom {\n      position: absolute;\n      bottom: 80px;\n      right: 70px;\n    }\n\n \n\n    /* Barra verde inferior */\n    .bottom-bar {\n      position: absolute;\n      bottom: 0;\n      left: 0;\n      width: 100%;\n      height: 22px;\n      background: #0f5e57;\n    }\n\n    /* Responsive */\n    @media(max-width:1024px) {\n      .hero-image {\n        display: none;\n      }\n\n      .hero-content {\n        margin-left: 0;\n        width: 100%;\n        padding: 0 30px;\n      }\n\n      .hero-content h1 {\n        font-size: 34px;\n        text-align: center;\n      }\n\n      .top-badge {\n        right: 20px;\n        top: 20px;\n      }\n\n      .logo-bottom {\n        right: 20px;\n        bottom: 100px;\n      }\n\n  \n    }\n\n    /* Animación pulso suave */\n    @keyframes pulse-hero {\n      0% { transform: scale(1); }\n      50% { transform: scale(1.015); }\n      100% { transform: scale(1); }\n    }\n  </style>\n</head>\n<body>\n\n  <section class=\"hero\">\n\n    <!-- Imagen izquierda animada -->\n    <div class=\"hero-image\"></div>\n\n    <!-- Título -->\n    <div class=\"hero-content\">\n      <h1>Profesores</h1>\n    </div>\n\n    <!-- Badge superior derecho -->\n    <div class=\"top-badge\">\n      <div class=\"badge-year\">2026</div>\n      <div class=\"badge-text\">\n        INGENIERÍA EN<br>\n        INTELIGENCIA ARTIFICIAL\n      </div>\n    </div>\n\n    <!-- Logo Unitrópico -->\n    <div class=\"logo-bottom\">\n      <img src=\"../img/logo_unitropico.png\" alt=\"Unitrópico\" width=\"180\">\n    </div>\n\n    <!-- Barra inferior -->\n    <div class=\"bottom-bar\"></div>\n\n  </section>\n\n</body>\n</html>",
  "allowScripts": true,
  "hotspots": []
}