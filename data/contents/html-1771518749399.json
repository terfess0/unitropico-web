{
  "id": "html-1771518749399",
  "title": "Relación de la Denominación",
  "type": "html",
  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Relación Denominación - Unitrópico</title>\n  <!-- Fuente Montserrat y CSS base -->\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n  <style>\n    /* =========================\n       ESTILOS ADICIONALES\n    ========================= */\n    html,\n    body {\n      height: 100%;\n      margin: 0;\n      overflow-x: hidden;\n      /* Imagen de fondo */\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    /* Navbar */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n    }\n\n    .navbar-img img {\n      width: 100%;\n      height: auto;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal */\n    .section-container {\n      position: relative;\n      width: 100%;\n      min-height: 90vh;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      padding-bottom: 0px;\n    }\n\n    /* Título verde (artículo) */\n    .top-left-title {\n      margin-left: 25px;\n      margin-top: 25px;\n    }\n\n    /* Área de composición (posición relativa para los absolutos) */\n    .main-layout {\n      position: relative;\n      width: 100%;\n      max-width: 1200px;\n      height: 600px;\n      /* Altura fija para el posicionamiento */\n      margin-top: 0px;\n    }\n\n    /* ===== CÍRCULOS ===== */\n    .circle-area {\n      position: absolute;\n      top: 50%;\n      left: 50%;\n      transform: translate(-50%, -50%);\n      width: 400px;\n      height: 400px;\n    }\n\n    .circle-ring {\n      position: absolute;\n      width: 100%;\n      height: 100%;\n      border: 20px solid var(--bronce-1);\n      border-radius: 50%;\n      box-sizing: border-box;\n      animation: ring-pulse 4s ease-in-out infinite;\n    }\n\n    @keyframes ring-pulse {\n      0% {\n        transform: scale(1);\n        opacity: 0.8;\n      }\n\n      50% {\n        transform: scale(1.02);\n        opacity: 1;\n      }\n\n      100% {\n        transform: scale(1);\n        opacity: 0.8;\n      }\n    }\n\n    .circle {\n      position: absolute;\n      width: 130px;\n      height: 130px;\n      border-radius: 50%;\n      background: var(--verde-2);\n      color: white;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n      font-weight: 600;\n      padding: 10px;\n      font-size: 14px;\n      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);\n      z-index: 5;\n      cursor: pointer;\n      transition: transform 0.3s ease, background 0.3s;\n    }\n\n    .circle.center {\n      width: 120px;\n      height: 120px;\n      top: 50%;\n      left: 50%;\n      transform: translate(-50%, -50%);\n      background: var(--verde-1);\n      cursor: default;\n\n    }\n\n    .circle.top {\n      top: -45px;\n      left: 50%;\n      transform: translateX(-50%);\n    }\n\n    .circle.right {\n      right: -45px;\n      top: 50%;\n      transform: translateY(-50%);\n    }\n\n    .circle.bottom {\n      bottom: -45px;\n      left: 50%;\n      transform: translateX(-50%);\n    }\n\n    .circle.left {\n      left: -45px;\n      top: 50%;\n      transform: translateY(-50%);\n    }\n\n    .circle:not(.center):hover {\n      background: var(--verde-3);\n      transform: scale(1.1) !important;\n    }\n\n    .circle.top:hover {\n      transform: translateX(-50%) scale(1.1) !important;\n    }\n\n    .circle.bottom:hover {\n      transform: translateX(-50%) scale(1.1) !important;\n    }\n\n    .circle.left:hover {\n      transform: translateY(-50%) scale(1.1) !important;\n    }\n\n    .circle.right:hover {\n      transform: translateY(-50%) scale(1.1) !important;\n    }\n\n    /* ===== CUADROS DE INFORMACIÓN ===== */\n    .info-box {\n      position: absolute;\n      background: white;\n      border: 2px solid var(--verde-1);\n      border-radius: 15px;\n      padding: 15px;\n      font-weight: 600;\n      text-align: center;\n      box-shadow: 0 10px 25px rgba(0, 89, 78, 0.2);\n      z-index: 10;\n      opacity: 0;\n      transform: scale(0.9);\n      transition: opacity 0.3s ease, transform 0.3s ease;\n      pointer-events: none;\n    }\n\n    .info-box.visible {\n      opacity: 1;\n      transform: scale(1);\n      pointer-events: auto;\n    }\n\n    #cuadroTitulo {\n      top: 20%;\n      left: 5%;\n      width: auto;\n      border-radius: 30px;\n      background: white;\n    }\n\n    /* Nivel (ahora a la derecha) */\n    #cuadroNivel {\n      top: 50%;\n      right: 2%;\n      transform: translateY(-50%);\n      width: auto;\n      min-width: 120px;\n      border-radius: 40px;\n      padding: 15px 25px;\n    }\n\n    /* Contenidos curriculares: grid 4x2, se adapta al contenido */\n    #cuadroContenidos {\n      bottom: 20%;\n      left: 5%;\n      width: auto;                /* se ajusta al contenido */\n      min-width: 260px;           /* un ancho mínimo cómodo */\n      border-radius: 30px;\n      padding: 20px;\n      background: white;\n      display: grid;\n      grid-template-columns: 1fr auto;  /* primera columna flexible, segunda ajustada */\n      gap: 10px 15px;              /* espacio vertical y horizontal */\n      align-items: center;\n      font-weight: 500;\n    }\n\n    /* Estilo para cada ítem dentro del grid */\n    .contenido-item {\n      display: contents;  /* para que los hijos se conviertan en celdas del grid */\n    }\n\n    .label-contenido {\n      text-align: left;\n      color: var(--bronce-1);\n      white-space: nowrap;      /* evita que el texto se divida en varias líneas */\n    }\n\n    .porcentaje-contenido {\n      text-align: right;\n      color: var(--verde-1);\n      font-weight: 700;\n      white-space: nowrap;\n    }\n\n    /* Badge superior derecho (opcional) */\n    .top-badge {\n      position: absolute;\n      top: 40px;\n      right: 60px;\n      display: flex;\n      align-items: center;\n      gap: 15px;\n    }\n\n    /* ===== RESPONSIVE ===== */\n    @media (max-width: 1000px) {\n      .main-layout {\n        height: auto;\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        padding-top: 80px;\n      }\n\n      .circle-area {\n        position: relative;\n        transform: none;\n        top: 0;\n        left: 0;\n        margin-bottom: 100px;\n      }\n\n      .info-box {\n        position: relative;\n        transform: none !important;\n        top: 0 !important;\n        left: 0 !important;\n        right: 0 !important;\n        margin: 10px auto !important;\n        width: 90% !important;\n        max-width: 300px;\n        opacity: 1;\n        transform: scale(1);\n        pointer-events: auto;\n      }\n\n      .info-box:not(.visible) {\n        display: none;\n      }\n    }\n\n    @media (max-width: 500px) {\n      .circle-area {\n        width: 280px;\n        height: 280px;\n      }\n\n      .circle {\n        width: 90px;\n        height: 90px;\n        font-size: 11px;\n      }\n\n      .circle.center {\n        width: 120px;\n        height: 120px;\n      }\n\n      .circle.top {\n        top: -35px;\n      }\n\n      .circle.right {\n        right: -35px;\n      }\n\n      .circle.bottom {\n        bottom: -35px;\n      }\n\n      .circle.left {\n        left: -35px;\n      }\n    }\n  </style>\n</head>\n\n<body>\n\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"section-container\">\n    <div class=\"top-left-title subtitulo text-verde-1\">\n      Artículo 2.5.3.2.3.2.2. Relación de la denominación con el título a otorgar, con el nivel de formación, con los\n      contenidos curriculares y con el perfil de egreso\n    </div>\n\n    <div class=\"main-layout\">\n\n      <!-- Cuadros de información -->\n      <div class=\"info-box text-bronce-1\" id=\"cuadroTitulo\">\n        Ingeniero (a) en Inteligencia Artificial\n      </div>\n      \n      <div class=\"info-box text-bronce-1\" id=\"cuadroNivel\">\n        Pregrado\n      </div>\n      \n      <!-- Cuadro de Contenidos Curriculares en grid 4x2 -->\n      <div class=\"info-box\" id=\"cuadroContenidos\">\n        <span class=\"label-contenido\">Formación Profesional</span>\n        <span class=\"porcentaje-contenido\">69,5%</span>\n        <span class=\"label-contenido\">Praxis Investigativa</span>\n        <span class=\"porcentaje-contenido\">9,5%</span>\n        <span class=\"label-contenido\">Formación Integral</span>\n        <span class=\"porcentaje-contenido\">12,2%</span>\n        <span class=\"label-contenido\">Libre Elección</span>\n        <span class=\"porcentaje-contenido\">8,8%</span>\n      </div>\n\n      <!-- Círculos -->\n      <div class=\"circle-area\">\n        <div class=\"circle-ring\"></div>\n\n        <div class=\"circle center\">\n          Ingeniería en<br>Inteligencia Artificial\n        </div>\n\n        <div class=\"circle top\" id=\"btnTitulo\">Título que<br>otorga</div>\n        <div class=\"circle right\" id=\"btnNivel\">Nivel de<br>formación</div>\n        <div class=\"circle bottom\" id=\"btnPerfil\">Perfil del<br>Egreso</div>\n        <div class=\"circle left\" id=\"btnContenidos\">Contenidos<br>Curriculares</div>\n      </div>\n\n    </div>\n  </div>\n\n  <script>\n    function setupToggle(btnId, boxId) {\n      const btn = document.getElementById(btnId);\n      const box = document.getElementById(boxId);\n      if (!btn || !box) return;\n\n      btn.addEventListener('click', (e) => {\n        e.stopPropagation();\n        if (window.innerWidth < 1000) {\n          document.querySelectorAll('.info-box').forEach(b => {\n            if (b.id !== boxId) b.classList.remove('visible');\n          });\n        }\n        box.classList.toggle('visible');\n      });\n    }\n\n    setupToggle('btnTitulo', 'cuadroTitulo');\n    setupToggle('btnNivel', 'cuadroNivel');\n    setupToggle('btnContenidos', 'cuadroContenidos');\n\n    const btnPerfil = document.getElementById('btnPerfil');\n    if (btnPerfil) {\n      btnPerfil.addEventListener('click', (e) => {\n        e.stopPropagation();\n        window.parent.postMessage({ type: 'NAVIGATE', targetId: 'html-1771522548284' }, '*');\n      });\n    }\n\n    document.addEventListener('click', (e) => {\n      if (!e.target.closest('.circle') && !e.target.closest('.info-box')) {\n        document.querySelectorAll('.info-box').forEach(box => box.classList.remove('visible'));\n      }\n    });\n  </script>\n\n</body>\n\n</html>",
  "allowScripts": true,
  "hotspots": []
}