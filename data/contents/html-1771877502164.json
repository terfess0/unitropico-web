{
  "id": "html-1771877502164",
  "title": "Estrategias de seguimiento",
  "type": "html",
  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Justificación - Oferta Internacional - Unitrópico</title>\n  <!-- Fuente Montserrat y CSS base -->\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n  <style>\n    /* =========================\n       ESTILOS ADICIONALES\n    ========================= */\n    html,\n    body {\n      height: 100%;\n      margin: 0;\n      overflow-x: hidden;\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    /* Navbar */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n    }\n\n    .navbar-img img {\n      width: 100%;\n      height: auto;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal */\n    .container {\n      max-width: 1100px;\n      margin: 30px auto;\n      padding: 0 25px;\n    }\n\n    /* Título del artículo (izquierda) */\n    .top-left-title {\n      margin-bottom: 20px;\n      color: var(--verde-1);\n    }\n\n    /* Encabezado de sección centrado con dos líneas */\n    .section-header-line {\n      margin-bottom: 40px;\n      text-align: center;\n    }\n\n    .section-header-line h2 {\n      font-size: 2.5rem;\n      font-weight: 700;\n      color: var(--verde-1);\n      margin: 0 0 15px 0;\n      line-height: 1.2;\n    }\n\n    /* Contenedor de las líneas (flex column para centrarlas) */\n    .lines-container {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 0px;\n      /* espacio entre líneas */\n    }\n\n    /* Línea dorada (larga y delgada) */\n    .line-gold {\n      width: 300px;\n      height: 3px;\n      background-color: var(--bronce-1);\n      border-radius: 2px;\n    }\n\n    /* Línea gris (más corta y más alta) */\n    .line-gray {\n      width: 150px;\n      height: 6px;\n      background-color: #A0A0A0;\n      /* gris suave, puedes cambiarlo por --bronce-4 si prefieres */\n      border-radius: 3px;\n    }\n\n    /* Estilos para el diagrama circular */\n    .cycle-wrapper {\n      position: relative;\n      width: 1000px;\n      height: 480px;\n      left: 50%;\n      margin: 40px 0 50px -500px;\n      transform-origin: top center;\n    }\n    .cycle-svg {\n      position: absolute;\n      top: 0;\n      left: 0;\n      width: 100%;\n      height: 100%;\n      z-index: 0;\n    }\n    .node {\n      position: absolute;\n      transform: translate(-50%, -50%);\n      z-index: 1;\n    }\n    .node-box {\n      width: 170px;\n      height: 115px;\n      border-radius: 12px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n      font-weight: 700;\n      font-size: 0.95rem;\n      padding: 15px;\n      box-sizing: border-box;\n      box-shadow: 0 0 0 8px white;\n    }\n    .node-label {\n      border: 2px solid var(--verde-1, #004b40);\n      background-color: white;\n      color: var(--verde-1, #004b40);\n      font-weight: 600;\n      font-size: 0.9rem;\n      padding: 5px 10px;\n      white-space: nowrap;\n      position: absolute;\n      top: 50%;\n      transform: translateY(-50%);\n    }\n\n    /* Responsive */\n    @media (max-width: 1100px) {\n      .cycle-wrapper {\n        transform: scale(0.8);\n        margin-bottom: -90px;\n      }\n    }\n    @media (max-width: 768px) {\n      .container {\n        margin: 15px;\n        padding: 0 15px;\n      }\n      .section-header-line h2 {\n        font-size: 1.5rem !important;\n      }\n      .line-gold {\n        width: 100% !important;\n        max-width: 550px;\n      }\n      .line-gray {\n        width: 80% !important;\n        max-width: 450px;\n      }\n      .cycle-wrapper {\n        transform: scale(0.4);\n        margin-bottom: -280px;\n      }\n    }\n  </style>\n</head>\n\n<body>\n  <!-- Navbar de imagen -->\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"container\">\n    <!-- Título del artículo (alineado izquierda) -->\n    <div class=\"top-left-title subtitulo text-verde-1\" style=\"font-weight: 700; font-size: 1.05rem;\">\n      <span class=\"text-verde-1\">2.5.3.2.3.2.5. Organización de actividades académicas y proceso formativo</span>\n    </div>\n\n    <!-- Encabezado centrado con dos líneas -->\n    <div class=\"section-header-line\">\n      <h2 style=\"font-weight: 400; font-size: 2.1rem; line-height: 1.4; color: #007580;\">\n        Estrategias de seguimiento al proceso formativo que facilite su<br>\n        <strong style=\"color: var(--verde-1, #004b40);\">permanencia, graduación y logro de los resultados de aprendizaje</strong>\n      </h2>\n      <div class=\"lines-container\" style=\"margin-top: 15px;\">\n        <div class=\"line-gold\" style=\"width: 550px;\"></div>\n        <div class=\"line-gray\" style=\"width: 450px;\"></div>\n      </div>\n    </div>\n\n    <!-- Contenido: Diagrama Circular -->\n    <div class=\"cycle-wrapper\">\n      <svg class=\"cycle-svg\" width=\"1000\" height=\"450\" viewBox=\"0 0 1000 450\">\n        <circle cx=\"500\" cy=\"240\" r=\"150\" fill=\"none\" stroke=\"#004b40\" stroke-width=\"2.5\" />\n      </svg>\n\n      <!-- Nodo 1: Top -->\n      <div class=\"node\" style=\"left: 500px; top: 90px;\">\n        <div class=\"node-box\" style=\"background-color: var(--verde-1, #004b40); color: white;\">\n          Estatuto de<br>Bienestar\n        </div>\n        <div class=\"node-label\" style=\"left: 100%; margin-left: 20px;\">\n          REC No. 021 de 2021\n        </div>\n      </div>\n\n      <!-- Nodo 2: Bottom-Left -->\n      <div class=\"node\" style=\"left: 370px; top: 315px;\">\n        <div class=\"node-box\" style=\"background-color: #a0a0a0; color: white;\">\n          Plan de<br>Acompañamiento<br>y Seguimiento<br>Estudiantil, PASE\n        </div>\n        <div class=\"node-label\" style=\"right: 100%; margin-right: 20px;\">\n          REC No. 581 de 2023\n        </div>\n      </div>\n\n      <!-- Nodo 3: Bottom-Right -->\n      <div class=\"node\" style=\"left: 630px; top: 315px;\">\n        <div class=\"node-box\" style=\"background-color: var(--bronce-1, #ba9b5e); color: white;\">\n          Política Integral de<br>Bienestar\n        </div>\n        <div class=\"node-label\" style=\"left: 100%; margin-left: 20px;\">\n          Acuerdo CS No. 044 de 2023\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- Badge Vigilada MinEducación (comentado) -->\n  <!-- <div class=\"vigilada\">– Vigilada MinEducación –</div> -->\n</body>\n\n</html>",
  "allowScripts": true,
  "hotspots": []
}