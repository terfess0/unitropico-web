{
  "id": "html-1771912466121",
  "title": "Descripción y diseño de los mecanismos de evaluación",
  "type": "html",
  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Justificación - Oferta Internacional - Unitrópico</title>\n  <!-- Fuente Montserrat y CSS base -->\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n  <style>\n    /* =========================\n       ESTILOS ADICIONALES\n    ========================= */\n    html,\n    body {\n      height: 100%;\n      margin: 0;\n      overflow-x: hidden;\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    /* Navbar */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n    }\n\n    .navbar-img img {\n      width: 100%;\n      height: auto;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal */\n    .container {\n      max-width: 1100px;\n      margin: 30px auto;\n      padding: 0 25px;\n    }\n\n    /* Estilos para Estrategias de flexibilización */\n    .section-header-line {\n      margin-bottom: 40px;\n      text-align: center;\n      padding-top: 10px;\n    }\n\n    .section-header-line h2 {\n      font-weight: 400;\n      font-size: 2.2rem;\n      line-height: 1.35;\n      color: #007580;\n      margin: 0 0 10px 0;\n    }\n\n    /* Estilos para el Icono Lateral */\n    .comp-icon-row {\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      margin-top: 80px;\n      margin-bottom: 90px;\n      gap: 30px;\n    }\n\n    .comp-icon-container {\n      width: 140px;\n      height: 140px;\n      background-color: #fcfcfc;\n      border-radius: 50%;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08), inset 0 2px 10px rgba(0, 0, 0, 0.02);\n      border: 3px solid #f2f2f2;\n    }\n\n    .comp-icon-container img {\n      width: 55%;\n      height: auto;\n    }\n\n    .comp-text-title {\n      font-size: 2.2rem;\n      font-weight: 700;\n      color: #007580;\n    }\n\n    @media (max-width: 768px) {\n      .container {\n        margin: 15px;\n        padding: 0 15px;\n      }\n\n      .comp-icon-row {\n        flex-direction: column;\n        gap: 15px;\n      }\n\n      .comp-text-title {\n        font-size: 1.8rem;\n      }\n\n      .section-header-line h2 {\n        font-size: 1.5rem !important;\n      }\n\n      .line-gold {\n        width: 100% !important;\n        max-width: 550px;\n      }\n\n      .line-gray {\n        width: 80% !important;\n        max-width: 450px;\n      }\n    }\n\n    /* =========================================\n       NUEVO LAYOUT: MECANISMOS DE EVALUACION\n       ========================================= */\n    .eval-header {\n      margin-top: 50px;\n      margin-bottom: 50px;\n      text-align: center;\n    }\n\n    .eval-header h2 {\n      font-weight: 700;\n      font-size: 2.3rem;\n      color: #007580;\n      margin: 0 0 10px 0;\n    }\n    .eval-header h2 span {\n      font-weight: 300;\n      color: #007580;\n    }\n\n    .eval-container {\n      display: flex;\n      max-width: 1000px;\n      margin: 0 auto;\n      gap: 60px;\n      align-items: center;\n      justify-content: center;\n      padding-bottom: 80px;\n    }\n\n    .eval-col {\n      flex: 1;\n      display: flex;\n      justify-content: center;\n    }\n\n    /* Diagrama Base */\n    .diagram-wrapper {\n      position: relative;\n      width: 300px;\n      height: 300px;\n      margin: 30px auto;\n    }\n\n    /* Diagrama Izquierdo (Evaluación) */\n    .ring-mask {\n      position: absolute;\n      top: 0; left: 0; right: 0; bottom: 0;\n      border-radius: 50%;\n      background: conic-gradient(\n        #00594e 0deg 72deg,\n        #bfa773 72deg 144deg,\n        #009b85 144deg 216deg,\n        #00b2a9 216deg 288deg,\n        #afafaf 288deg 360deg\n      );\n      -webkit-mask: radial-gradient(closest-side, transparent calc(100% - 13px), black calc(100% - 12px));\n      mask: radial-gradient(closest-side, transparent calc(100% - 13px), black calc(100% - 12px));\n      z-index: 1;\n    }\n\n    .eval-node {\n      position: absolute;\n      width: 96px;\n      height: 96px;\n      border-radius: 50%;\n      color: white;\n      font-weight: 700;\n      font-size: 0.82rem;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n      transform: translate(-50%, -50%);\n      box-shadow: 0 4px 6px rgba(0,0,0,0.1);\n      z-index: 2;\n    }\n    .node-c1 { background-color: #00594e; left: 50%; top: 0%; }\n    .node-c2 { background-color: #bfa773; left: 97.55%; top: 34.55%; }\n    .node-c3 { background-color: #009b85; left: 79.39%; top: 90.45%; }\n    .node-c4 { background-color: #00b2a9; left: 20.61%; top: 90.45%; }\n    .node-c5 { background-color: #afafaf; left: 2.45%; top: 34.55%; }\n\n    .eval-inner {\n      position: absolute;\n      width: 156px;\n      height: 156px;\n      background: white;\n      border-radius: 50%;\n      left: 50%;\n      top: 50%;\n      transform: translate(-50%, -50%);\n      box-shadow: 0 8px 15px rgba(0,0,0,0.1);\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      font-weight: 700;\n      font-size: 1.25rem;\n      color: #007580;\n      z-index: 10;\n    }\n    .eval-inner::before {\n      content: '';\n      position: absolute;\n      width: 105%; height: 105%;\n      border-radius: 50%;\n      background-color: #ffb703; /* Borde amarillo resplandeciente */\n      top: 0; left: 0;\n      transform: translate(3px, 5px); /* Desfase asimétrico */\n      z-index: -1;\n    }\n\n    /* Diagrama Derecho (Estudiante) */\n    .est-node {\n      position: absolute;\n      width: 98px;\n      height: 98px;\n      border-radius: 50%;\n      color: white;\n      font-weight: 700;\n      font-size: 0.8rem;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n      transform: translate(-50%, -50%);\n      box-shadow: 0 4px 6px rgba(0,0,0,0.1);\n      z-index: 2;\n    }\n    .est-n1 { background-color: #00594e; left: 50%; top: 0%; }\n    .est-n2 { background-color: #009b85; left: 100%; top: 50%; }\n    .est-n3 { background-color: #666666; left: 50%; top: 100%; }\n    .est-n4 { background-color: #bfa773; left: 0%; top: 50%; }\n\n    .est-inner {\n      position: absolute;\n      width: 130px;\n      height: 130px;\n      background: white;\n      border-radius: 50%;\n      left: 50%;\n      top: 50%;\n      transform: translate(-50%, -50%);\n      box-shadow: 0 8px 15px rgba(0,0,0,0.08); \n      display: flex;\n      align-items: center;\n      justify-content: center;\n      font-weight: 700;\n      font-size: 1.15rem;\n      color: #007580;\n      z-index: 10;\n    }\n    .est-inner::after {\n      content: '';\n      position: absolute;\n      top: 6px; left: 6px; right: 6px; bottom: 6px;\n      border-radius: 50%;\n      border: 4px solid #f9f9f9;\n    }\n\n    .est-arrow {\n      position: absolute;\n      width: 44px;\n      height: 22px;\n      background-color: #ebebeb;\n      clip-path: polygon(0 35%, 60% 35%, 60% 0, 100% 50%, 60% 100%, 60% 65%, 0 65%);\n      z-index: 1;\n    }\n    .earrow-tr { top: 25%; left: 75%; transform: translate(-50%, -50%) rotate(45deg); }\n    .earrow-rb { top: 75%; left: 75%; transform: translate(-50%, -50%) rotate(135deg); }\n    .earrow-bl { top: 75%; left: 25%; transform: translate(-50%, -50%) rotate(225deg); }\n    .earrow-lt { top: 25%; left: 25%; transform: translate(-50%, -50%) rotate(315deg); }\n\n    @media (max-width: 900px) {\n      .eval-container {\n        flex-direction: column;\n        gap: 90px;\n      }\n    }\n  </style>\n</head>\n\n<body>\n  <!-- Navbar de imagen -->\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"container\">\n    <!-- Título del artículo (alineado izquierda) -->\n    <div class=\"top-left-title subtitulo text-verde-1\">\n      <span class=\"text-bronce-1\">2.5.3.2.3.2.4. Aspectos curriculares -</span> e) Mecanismos de Evaluación\n    </div>\n\n    <!-- Encabezado centrado -->\n    <div class=\"eval-header\">\n      <h2><span>Descripción y diseño de<br></span>los mecanismos de evaluación</h2>\n      <div style=\"display: flex; flex-direction: column; align-items: center; gap: 0px;\">\n        <div class=\"line-gold\" style=\"width: 450px; height: 3px; background-color: #ba9b5e; border-radius: 2px;\"></div>\n        <div class=\"line-gray\" style=\"width: 400px; height: 6px; background-color: #e0e0e0; border-radius: 3px;\"></div>\n      </div>\n    </div>\n\n    <!-- Contenedor Evaluación Graficos Creados Desde Cero -->\n    <div class=\"eval-container\">\n      \n      <!-- Diagrama Evaluación (Izquierda) -->\n      <div class=\"eval-col\">\n        <div class=\"diagram-wrapper\">\n          <div class=\"ring-mask\"></div>\n          \n          <div class=\"eval-node node-c1\">Continua</div>\n          <div class=\"eval-node node-c2\">Integral</div>\n          <div class=\"eval-node node-c3\">Formativa</div>\n          <div class=\"eval-node node-c4\">Pertinente</div>\n          <div class=\"eval-node node-c5\">Participativa</div>\n\n          <div class=\"eval-inner\">Evaluación</div>\n        </div>\n      </div>\n\n      <!-- Diagrama Estudiante (Derecha) -->\n      <div class=\"eval-col\">\n        <div class=\"diagram-wrapper\" style=\"width: 270px; height: 270px; margin-top: 45px;\">\n          \n          <div class=\"est-arrow earrow-tr\"></div>\n          <div class=\"est-arrow earrow-rb\"></div>\n          <div class=\"est-arrow earrow-bl\"></div>\n          <div class=\"est-arrow earrow-lt\"></div>\n\n          <div class=\"est-node est-n1\">Resultados<br>de<br>Aprendizaje</div>\n          <div class=\"est-node est-n2\">Estrategias<br>de<br>Evaluación</div>\n          <div class=\"est-node est-n3\">Retro<br>alimentación</div>\n          <div class=\"est-node est-n4\">Estrategias<br>de<br>Enseñanza</div>\n\n          <div class=\"est-inner\">Estudiante</div>\n        </div>\n      </div>\n      \n    </div>\n\n  </div>\n</body>\n\n</html>",
  "allowScripts": true,
  "hotspots": []
}