{
  "id": "html-1771880452106",
  "title": "Estrategias de flexibilización para el desarrollo del programa",
  "type": "html",
  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Justificación - Oferta Internacional - Unitrópico</title>\n  <!-- Fuente Montserrat y CSS base -->\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n  <style>\n    /* =========================\n       ESTILOS ADICIONALES\n    ========================= */\n    html,\n    body {\n      height: 100%;\n      margin: 0;\n      overflow-x: hidden;\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    /* Navbar */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n    }\n\n    .navbar-img img {\n      width: 100%;\n      height: auto;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal */\n    .container {\n      max-width: 1100px;\n      margin: 30px auto;\n      padding: 0 25px;\n    }\n\n    /* Estilos para Estrategias de flexibilización */\n    .section-header-line {\n      margin-bottom: 10px;\n      text-align: center;\n      padding-top: 10px;\n    }\n\n    .section-header-line h2 {\n      font-weight: 400;\n      font-size: 2.2rem;\n      line-height: 1.35;\n      color: #007580;\n      margin: 0 0 10px 0;\n    }\n\n    .estrategias-container {\n      position: relative;\n      width: 100%;\n      height: 580px;\n      margin: 0 auto 60px auto;\n      display: flex;\n      justify-content: center;\n      overflow: hidden;\n    }\n\n    .circle-layer {\n      position: absolute;\n      bottom: 0;\n      border-radius: 50%;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      color: #ffffff;\n      font-weight: 700;\n      text-align: center;\n      font-size: 0.95rem;\n      line-height: 1.25;\n      box-sizing: border-box;\n    }\n\n    /* Ajuste de cada capa y su espacio de texto (radio) */\n    .layer-1 {\n      width: 620px;\n      height: 565px;\n      background-color: #11cbb0;\n      padding-top: 25px;\n      z-index: 1;\n    }\n\n    .layer-2 {\n      width: 510px;\n      height: 460px;\n      background-color: #106758;\n      padding-top: 22px;\n      z-index: 2;\n      font-size: 0.85rem;\n    }\n\n    .layer-3 {\n      width: 390px;\n      height: 350px;\n      background-color: #a0d575;\n      padding-top: 25px;\n      z-index: 3;\n    }\n\n    .layer-4 {\n      width: 290px;\n      height: 250px;\n      background-color: #13b5b1;\n      padding-top: 25px;\n      z-index: 4;\n    }\n\n    .layer-5 {\n      width: 210px;\n      height: 170px;\n      background-color: #bca45d;\n      padding-top: 25px;\n      z-index: 5;\n    }\n\n    .layer-6 {\n      width: 140px;\n      height: 120px;\n      background-color: #8d773f;\n      padding-top: 18px;\n      font-size: 0.85rem;\n      z-index: 6;\n    }\n\n    .layer-7 {\n      width: 80px;\n      height: 80px;\n      background-color: #ffffff;\n      color: #007580;\n      padding-top: 0;\n      justify-content: center;\n      z-index: 7;\n      font-weight: 800;\n      font-size: 0.75rem;\n      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);\n    }\n\n    /* Responsive */\n    @media (max-width: 768px) {\n      .container {\n        margin: 15px;\n        padding: 0 15px;\n      }\n\n      .estrategias-container {\n        transform: scale(0.65);\n        transform-origin: top center;\n        height: 420px;\n      }\n\n      .section-header-line h2 {\n        font-size: 1.5rem !important;\n      }\n\n      .line-gold {\n        width: 100% !important;\n        max-width: 550px;\n      }\n\n      .line-gray {\n        width: 80% !important;\n        max-width: 450px;\n      }\n    }\n  </style>\n</head>\n\n<body>\n  <!-- Navbar de imagen -->\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"container\">\n\n    <div class=\"container\">\n    <!-- Título del artículo (alineado izquierda) -->\n    <div class=\"top-left-title subtitulo text-verde-1\">\n      <span class=\"text-bronce-1\">Artículo 2.5.3.2.3.2.4.</span> Aspectos curriculares - a) Componentes formativos\n    </div>\n\n    <!-- Encabezado centrado de Estrategias -->\n    <div class=\"section-header-line\">\n      <h2>\n        Estrategias de flexibilización <strong style=\"color: #004b40; font-weight: 700;\">para el<br>desarrollo del\n          programa</strong>\n      </h2>\n      <div style=\"display: flex; flex-direction: column; align-items: center; gap: 0px;\">\n        <div class=\"line-gold\" style=\"width: 550px; height: 3px; background-color: #ba9b5e; border-radius: 2px;\"></div>\n        <div class=\"line-gray\" style=\"width: 450px; height: 6px; background-color: #e0e0e0; border-radius: 3px;\"></div>\n      </div>\n    </div>\n\n    <!-- Contenido: Círculos concéntricos  -->\n    <div class=\"estrategias-container\">\n      <div class=\"circle-layer layer-1\">\n        <span>Movilidad académica<br>saliente</span>\n      </div>\n      <div class=\"circle-layer layer-2\">\n        <span>Homologaciones y<br>Transferencias<br>Internas y externas</span>\n      </div>\n      <div class=\"circle-layer layer-3\">\n        <span>Asignaturas<br>Electivas y<br>Optativas</span>\n      </div>\n      <div class=\"circle-layer layer-4\">\n        <span>Cursos<br>Intersemestrales</span>\n      </div>\n      <div class=\"circle-layer layer-5\">\n        <span>Supletorios</span>\n      </div>\n      <div class=\"circle-layer layer-6\">\n        <span>Doble titulación</span>\n      </div>\n      <div class=\"circle-layer layer-7\">\n        <span>Estrategias</span>\n      </div>\n    </div>\n\n  </div>\n</body>\n\n</html>",
  "allowScripts": true,
  "hotspots": []
}