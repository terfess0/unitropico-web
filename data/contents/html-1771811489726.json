{
  "id": "html-1771811489726",
  "title": "Discriminación Horas",
  "type": "html",
  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Justificación - Oferta Internacional - Unitrópico</title>\n  <!-- Fuente Montserrat y CSS base -->\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n  <style>\n    /* =========================\n       ESTILOS ADICIONALES\n    ========================= */\n    html,\n    body {\n      height: 100%;\n      margin: 0;\n      overflow-x: hidden;\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    /* Navbar */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n    }\n\n    .navbar-img img {\n      width: 100%;\n      height: auto;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal */\n    .container {\n      max-width: 1100px;\n      margin: auto;\n      padding: 0 25px;\n    }\n\n    /* Título del artículo (izquierda) */\n    .top-left-title {\n      margin-bottom: 20px;\n      color: var(--verde-1);\n    }\n\n    /* Encabezado de sección centrado con dos líneas */\n    .section-header-line {\n      margin-bottom: 40px;\n      text-align: center;\n    }\n\n    .section-header-line h2 {\n      font-size: 2.5rem;\n      font-weight: 700;\n      color: var(--verde-1);\n      margin: 0 0 15px 0;\n      line-height: 1.2;\n    }\n\n    /* Contenedor de las líneas (flex column para centrarlas) */\n    .lines-container {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 0px;\n      /* espacio entre líneas */\n    }\n\n    /* Línea dorada (larga y delgada) */\n    .line-gold {\n      width: 300px;\n      height: 3px;\n      background-color: var(--bronce-1);\n      border-radius: 2px;\n    }\n\n    /* Línea gris (más corta y más alta) */\n    .line-gray {\n      width: 150px;\n      height: 6px;\n      background-color: #A0A0A0;\n      /* gris suave, puedes cambiarlo por --bronce-4 si prefieres */\n      border-radius: 3px;\n    }\n\n    /* --- Estilos Discriminación Horas --- */\n    .diagram-container {\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      gap: 15px;\n      margin-top: 50px;\n      margin-bottom: 60px;\n      flex-wrap: wrap;\n    }\n\n    .dia-circle {\n      background-color: #C3E0B5;\n      color: #00563F;\n      width: 140px;\n      height: 140px;\n      border-radius: 50%;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n      font-weight: 700;\n      font-size: 1.05rem;\n      line-height: 1.2;\n      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);\n    }\n\n    .arrow-right {\n      width: 40px;\n      height: 16px;\n      background-color: #00563F;\n      position: relative;\n    }\n\n    .arrow-right::after {\n      content: '';\n      position: absolute;\n      top: 50%;\n      right: -16px;\n      transform: translateY(-50%);\n      border-top: 15px solid transparent;\n      border-bottom: 15px solid transparent;\n      border-left: 17px solid #00563F;\n    }\n\n    .dia-pill {\n      background-color: #A0A0A0;\n      color: #FFFFFF;\n      width: 280px;\n      min-height: 70px;\n      border-radius: 35px;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n      line-height: 1.1;\n      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);\n      padding: 10px 0;\n    }\n\n    .dia-box {\n      background-color: #D3C398;\n      border: 2px solid #B8A375;\n      color: #00563F;\n      width: 170px;\n      min-height: 90px;\n      border-radius: 12px;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n      font-weight: 700;\n      line-height: 1.2;\n      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);\n      padding: 10px 0;\n    }\n\n    /* Tabla Grid */\n    .table-responsive {\n      width: 100%;\n      overflow-x: auto;\n    }\n\n    .disc-table {\n      display: grid;\n      grid-template-columns: 180px repeat(9, 1fr);\n      gap: 0;\n      width: 100%;\n      max-width: 850px;\n      margin: 0 auto 60px auto;\n      align-items: stretch;\n      font-family: 'Montserrat', sans-serif;\n      border-top: 1px solid black;\n      border-left: 1px solid black;\n    }\n\n    .disc-table>div {\n      border-right: 1px solid black;\n      border-bottom: 1px solid black;\n      box-sizing: border-box;\n    }\n\n    .disc-cell {\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      padding: 12px 0;\n      font-weight: 700;\n      color: #00563F;\n    }\n\n    .th-gold {\n      background-color: #C09B66;\n      color: #FFFFFF;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n      font-weight: 700;\n    }\n\n    .th-green {\n      background-color: #00563F;\n      color: #FFFFFF;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n      font-weight: 700;\n    }\n\n    .span-6 {\n      grid-column: 1 / 7;\n    }\n\n    .col-8 {\n      grid-column: 8;\n    }\n\n    @media (max-width: 768px) {\n      .diagram-container {\n        flex-direction: column;\n        gap: 30px;\n      }\n\n      .arrow-right {\n        transform: rotate(90deg);\n        margin: 20px 0;\n      }\n\n      .disc-table {\n        min-width: 800px;\n        /* Force scroll */\n      }\n    }\n\n    /* --- Estilos para los Árboles Pequeños (Praxis, Integral, Electivas) --- */\n    .trees-container {\n      display: flex;\n      justify-content: center;\n      align-items: flex-end;\n      gap: 30px;\n      margin-top: 40px;\n      margin-bottom: 50px;\n      width: 100%;\n      flex-wrap: wrap;\n      /* Permitir que bajen en móviles */\n    }\n\n    .small-tree {\n      display: flex;\n      justify-content: center;\n    }\n\n    .small-tree ul {\n      padding-top: 20px;\n      position: relative;\n      display: flex;\n      justify-content: center;\n      padding-left: 0;\n      margin: 0;\n    }\n\n    .small-tree li {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      list-style-type: none;\n      position: relative;\n      padding: 20px 15px 0 15px;\n    }\n\n    /* Conectores horizontales superiores */\n    .small-tree li::before,\n    .small-tree li::after {\n      content: '';\n      position: absolute;\n      top: 0;\n      right: 50%;\n      border-top: 2px solid #5A8AC6;\n      width: 50%;\n      height: 20px;\n    }\n\n    .small-tree li::after {\n      right: auto;\n      left: 50%;\n      border-left: 2px solid #5A8AC6;\n    }\n\n    /* Raiz */\n    .small-tree li:only-child::after,\n    .small-tree li:only-child::before {\n      display: none;\n    }\n\n    .small-tree li:only-child {\n      padding-top: 0;\n    }\n\n    /* Puntas */\n    .small-tree li:first-child::before,\n    .small-tree li:last-child::after {\n      border: 0 none;\n    }\n\n    .small-tree li:last-child::before {\n      border-right: 2px solid #5A8AC6;\n    }\n\n    /* Conector vertical bajando del padre */\n    .small-tree ul ul::before {\n      content: '';\n      position: absolute;\n      top: 0;\n      left: 50%;\n      border-left: 2px solid #5A8AC6;\n      width: 0;\n      height: 20px;\n      margin-left: -1px;\n    }\n\n    /* Estilos para el nuevo formato en columnas (Praxis Investigativa) */\n    .courses-wrapper {\n      display: flex;\n      flex-direction: row;\n      margin-bottom: 50px;\n      width: 100%;\n      align-items: stretch;\n      gap: 15px;\n    }\n\n    .vertical-label {\n      writing-mode: vertical-rl;\n      transform: rotate(180deg);\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      padding: 15px 15px;\n      margin-right: 5px;\n      color: #FFFFFF;\n      font-weight: 700;\n      font-size: 1.15rem;\n      letter-spacing: 1px;\n    }\n\n    .courses-grid {\n      display: flex;\n      flex: 1;\n      gap: 15px;\n    }\n\n    .course-column {\n      flex: 1;\n      display: flex;\n      flex-direction: column;\n    }\n\n    .course-header {\n      display: flex;\n      align-items: center;\n      color: #FFFFFF;\n      font-weight: 700;\n      font-size: 1.05rem;\n      padding: 12px 15px;\n      min-height: 60px;\n      line-height: 1.2;\n      border: 3px solid #6C9BC9;\n    }\n\n    .square-white {\n      width: 14px;\n      height: 14px;\n      background-color: #FFFFFF;\n      margin-right: 12px;\n      flex-shrink: 0;\n    }\n\n    .course-list {\n      list-style: none;\n      padding: 0;\n      margin: 15px 0 0 0;\n      display: flex;\n      flex-direction: column;\n      gap: 12px;\n    }\n\n    .course-list li {\n      display: flex;\n      align-items: flex-start;\n      font-weight: 500;\n      font-size: 0.85rem;\n      line-height: 1.3;\n    }\n\n    .square-outline {\n      width: 14px;\n      height: 14px;\n      border: 3px solid #6C9BC9;\n      margin-right: 8px;\n      margin-top: 3px;\n      flex-shrink: 0;\n      background-color: transparent;\n    }\n\n    .border-blue {\n      border-color: #5A8AC6;\n    }\n\n    /* Nodos de los arboles pequeños */\n    .st-node {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      position: relative;\n      z-index: 2;\n    }\n\n    .st-node-root {\n      width: 140px;\n    }\n\n    .st-node-child {\n      width: 130px;\n    }\n\n    .st-title {\n      width: 100%;\n      color: #FFFFFF;\n      text-align: center;\n      padding: 8px 6px;\n      font-weight: 700;\n      font-size: 0.8rem;\n      min-height: 50px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      line-height: 1.2;\n    }\n\n    .st-subtitle {\n      background-color: #FFFFFF;\n      border: 1px solid #5A8AC6;\n      color: #333333;\n      padding: 2px 4px;\n      font-size: 0.65rem;\n      font-weight: 500;\n      margin-top: -8px;\n      z-index: 3;\n      position: relative;\n      white-space: nowrap;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n\n    /* Colores Específicos de los Nuevos Árboles */\n    .bg-st-praxis-root {\n      background-color: #0088B4;\n    }\n\n    .bg-st-praxis-c1 {\n      background-color: #3366CC;\n    }\n\n    .bg-st-praxis-c2 {\n      background-color: #9999FF;\n    }\n\n    .bg-st-praxis-c3 {\n      background-color: #8C8CB8;\n    }\n\n    .bg-st-integral-root {\n      background-color: #9B2945;\n    }\n\n    .bg-st-integral-c1 {\n      background-color: #A35ECA;\n    }\n\n    .bg-st-integral-c2 {\n      background-color: #FF7575;\n    }\n\n    .bg-st-eleccion-root {\n      background-color: #B28B5C;\n    }\n\n    /* Color mostaza/dorado */\n    .bg-st-eleccion-c1 {\n      background-color: #C09B66;\n    }\n\n    .color-teal {\n      color: var(--verde-1, #00563F);\n    }\n\n    .color-gold {\n      color: var(--bronce-1, #B29B5C);\n    }\n\n    .color-arrow {\n      color: #555555;\n      margin: 0 2px;\n    }\n\n    .color-gray {\n      color: #555555;\n    }\n\n    .color-blue-pct {\n      color: #2A5BA1;\n      font-weight: 700;\n    }\n\n    /* Porcentaje azul */\n    .color-gold-cred {\n      color: #B29B5C;\n      font-weight: 700;\n    }\n\n    /* Creditos dorado */\n\n    @media (max-width: 768px) {\n      .container {\n        margin: 15px;\n        padding: 0 15px;\n      }\n\n      .section-header-line h2 {\n        font-size: 2rem;\n      }\n\n      .line-gold {\n        width: 200px;\n      }\n\n      .line-gray {\n        width: 100px;\n      }\n\n      .courses-wrapper {\n        flex-direction: column;\n        align-items: center;\n      }\n\n      .vertical-label {\n        writing-mode: horizontal-tb;\n        transform: rotate(0deg);\n        width: 100%;\n        margin-right: 0;\n        margin-bottom: 20px;\n        padding: 10px;\n      }\n\n      .courses-grid {\n        flex-direction: column;\n        width: 100%;\n        gap: 30px;\n      }\n\n      .trees-container {\n        flex-direction: column;\n        align-items: center;\n        gap: 50px;\n      }\n    }\n  </style>\n</head>\n\n<body>\n  <!-- Navbar de imagen -->\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"container\">\n    <!-- Título del artículo (alineado izquierda) -->\n    <div class=\"top-left-title subtitulo text-verde-1\">\n      <span class=\"text-bronce-1\">2.5.3.2.3.2.5.</span> Organización de actividades académicas y proceso formativo\n    </div>\n\n    <!-- Encabezado centrado con dos líneas -->\n    <div class=\"section-header-line\">\n      <h2><span style=\"font-weight: 400;\" class=\"text-verde-2\">Discriminación</span> Horas</h2>\n      <div class=\"lines-container\">\n        <div class=\"line-gold\"></div>\n        <div class=\"line-gray\"></div>\n      </div>\n    </div>\n\n    <!-- Diagrama Superior -->\n    <div class=\"diagram-container\">\n      <!-- Modalidad presencial -->\n      <div class=\"dia-circle\">Modalidad<br>presencial</div>\n\n      <!-- Arrow -->\n      <div class=\"arrow-right\" style=\"margin: 0 15px;\"></div>\n\n      <!-- Pill -->\n      <div class=\"dia-pill\">\n        <span style=\"font-size: 1.4rem; font-weight: 700;\">148</span>\n        <span style=\"font-size: 1rem;\">créditos académicos</span>\n      </div>\n\n      <!-- Arrow -->\n      <div class=\"arrow-right\" style=\"margin: 0 15px;\"></div>\n\n      <!-- Square -->\n      <div class=\"dia-box\">\n        <span style=\"font-size: 1.2rem; font-weight: 700;\">9</span>\n        <span style=\"font-size: 0.9rem;\">periodos<br>académicos<br>semestrales</span>\n      </div>\n    </div>\n\n    <!-- Tabla Grid -->\n    <div class=\"table-responsive\">\n      <div class=\"disc-table\">\n\n        <!-- Fila 1 -->\n        <div class=\"th-gold\">Nivel<br>Académico</div>\n        <div class=\"disc-cell\">1</div>\n        <div class=\"disc-cell\">2</div>\n        <div class=\"disc-cell\">3</div>\n        <div class=\"disc-cell\">4</div>\n        <div class=\"disc-cell\">5</div>\n        <div class=\"disc-cell\">6</div>\n        <div class=\"disc-cell\">7</div>\n        <div class=\"disc-cell\">8</div>\n        <div class=\"disc-cell\">9</div>\n\n        <!-- Fila 2 -->\n        <div class=\"th-gold\">Créditos</div>\n        <div class=\"disc-cell\">16</div>\n        <div class=\"disc-cell\">16</div>\n        <div class=\"disc-cell\">16</div>\n        <div class=\"disc-cell\">17</div>\n        <div class=\"disc-cell\">16</div>\n        <div class=\"disc-cell\">16</div>\n        <div class=\"disc-cell\">16</div>\n        <div class=\"disc-cell\">18</div>\n        <div class=\"disc-cell\">17</div>\n\n        <!-- Fila 3 -->\n        <div class=\"th-green span-6\">Créditos obligatorios</div>\n        <div class=\"disc-cell\"></div>\n        <div class=\"disc-cell\">123</div>\n        <div class=\"disc-cell\"></div>\n        <div class=\"disc-cell\"></div>\n\n        <!-- Fila 4 -->\n        <div class=\"th-green span-6\">Créditos electivos</div>\n        <div class=\"disc-cell\"></div>\n        <div class=\"disc-cell\">25</div>\n        <div class=\"disc-cell\"></div>\n        <div class=\"disc-cell\"></div>\n\n      </div>\n    </div>\n\n  </div>\n\n  <!-- Badge Vigilada MinEducación (comentado) -->\n  <!-- <div class=\"vigilada\">– Vigilada MinEducación –</div> -->\n</body>\n\n</html>",
  "allowScripts": true,
  "hotspots": []
}