{
  "id": "html-1771878004713",
  "title": "Nueva Diapositiva HTML",
  "type": "html",
  "html": "<!DOCTYPE html>\n<html lang=\"es\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Justificación - Oferta Internacional - Unitrópico</title>\n  <!-- Fuente Montserrat y CSS base -->\n  <link rel=\"stylesheet\" href=\"../css_presentaciones/unitropico_base.css\">\n  <style>\n    /* =========================\n       ESTILOS ADICIONALES\n    ========================= */\n    html,\n    body {\n      height: 100%;\n      margin: 0;\n      overflow-x: hidden;\n      background: url(\"../img/background-1.jpg\") no-repeat center center fixed;\n      background-size: cover;\n      font-family: 'Montserrat', sans-serif;\n    }\n\n    /* Navbar */\n    .navbar-img {\n      width: 100%;\n      background: var(--verde-1);\n      text-align: center;\n    }\n\n    .navbar-img img {\n      width: 100%;\n      height: auto;\n      max-height: 110px;\n      object-fit: contain;\n      display: block;\n    }\n\n    /* Contenedor principal */\n    .container {\n      max-width: 1400px;\n      margin: 30px auto;\n      padding: 0 25px;\n    }\n\n    /* Estilos para Estructura Orgánica HTML */\n    .org-outer-container {\n      width: 100%;\n      overflow-x: auto;\n      margin-top: 20px;\n      margin-bottom: 50px;\n      padding-bottom: 20px;\n    }\n\n    .org-chart-box {\n      min-width: 1100px;\n      padding: 30px 20px;\n      background: #fafafa;\n      border: 1px solid #e0e0e0;\n      border-radius: 12px;\n      font-family: 'Montserrat', sans-serif;\n      color: #333;\n    }\n\n    .org-header {\n      text-align: center;\n      position: relative;\n    }\n\n    .org-header h2 {\n      font-size: 1.8rem;\n      color: #004b40;\n      margin: 0;\n      font-weight: 700;\n    }\n\n    .org-header h3 {\n      font-size: 1.4rem;\n      color: #ba9b5e;\n      margin: 5px 0 40px 0;\n      font-weight: 500;\n    }\n\n    .org-node {\n      border: 2px solid;\n      border-left-width: 10px;\n      border-right-width: 10px;\n      border-radius: 18px;\n      background: #fff;\n      font-size: 0.65rem;\n      font-weight: 700;\n      text-align: center;\n      padding: 6px 12px;\n      box-sizing: border-box;\n      line-height: 1.25;\n      z-index: 2;\n      position: relative;\n    }\n\n    .node-green {\n      border-color: #79a334;\n      color: #5a7d23;\n    }\n\n    .node-orange {\n      border-color: #df9127;\n      color: #b56e10;\n    }\n\n    .node-blue {\n      border-color: #129dbb;\n      color: #0a697d;\n    }\n\n    .node-purple {\n      border-color: #89308e;\n      color: #591b5d;\n    }\n\n    .org-vert-line {\n      width: 1px;\n      background: #b4b4b4;\n      position: relative;\n      z-index: 1;\n    }\n\n    .lg-line {\n      background: #b4b4b4;\n      height: 1px;\n      width: 15px;\n      z-index: 1;\n    }\n\n    /* 4 columns */\n    .org-footer-branch {\n      width: 100%;\n      max-width: 1200px;\n      margin: 0 auto;\n      display: flex;\n      justify-content: space-between;\n    }\n\n    .v-col {\n      width: 24%;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n    }\n\n    .v-box {\n      border: 1px solid #d0d0d0;\n      width: 100%;\n      border-radius: 4px;\n      padding: 15px 0 15px 15px;\n      display: flex;\n      flex-direction: column;\n      gap: 12px;\n      box-sizing: border-box;\n      background: #fafafa;\n      position: relative;\n    }\n\n    /* El spine gris de la izquierda para las sub-ramas */\n    .v-spine {\n      position: absolute;\n      left: 15px;\n      top: 15px;\n      bottom: 15px;\n      width: 1px;\n      background: #b4b4b4;\n    }\n\n    .v-row {\n      display: flex;\n      align-items: center;\n      position: relative;\n      margin-left: 15px;\n      /* Deja espacio al spine */\n    }\n\n    .h-line-left {\n      position: absolute;\n      left: -15px;\n      top: 50%;\n      width: 15px;\n      height: 1px;\n      background: #b4b4b4;\n    }\n\n    .h-line-mid {\n      width: 12px;\n      height: 1px;\n      background: #b4b4b4;\n      flex-shrink: 0;\n    }\n\n    .v-node-lg {\n      width: 140px;\n      flex-shrink: 0;\n    }\n\n    .v-node-sm {\n      width: 105px;\n      flex-shrink: 0;\n      padding-left: 5px;\n      padding-right: 5px;\n    }\n\n    .v-node-full {\n      width: 90%;\n    }\n\n    .v-node-admin {\n      width: 130px;\n      flex-shrink: 0;\n    }\n\n    .v-node-admin-sm {\n      width: 100px;\n      flex-shrink: 0;\n    }\n\n    /* Responsive */\n    @media (max-width: 768px) {\n      .container {\n        margin: 15px;\n        padding: 0 15px;\n        max-width: 100%;\n      }\n\n      .org-chart-box {\n        padding: 15px 10px;\n      }\n    }\n  </style>\n</head>\n\n<body>\n  <!-- Navbar de imagen -->\n  <div class=\"navbar-img\">\n    <img src=\"media/denominacion/navbar.png\" alt=\"Navbar Unitropico\">\n  </div>\n\n  <div class=\"container\">\n    <!-- Contenido: Estructura Orgánica HTML -->\n    <div class=\"org-outer-container\">\n      <div class=\"org-chart-box\">\n        <div class=\"org-header\">\n          <h2>Estructura Orgánica</h2>\n          <h3>Unitrópico</h3>\n        </div>\n\n        <!-- Top Hierarchy -->\n        <div\n          style=\"position: relative; width: 100%; max-width: 900px; margin: 0 auto; display: flex; flex-direction: column; align-items: center;\">\n          <!-- CSU -->\n          <div class=\"org-node node-green\" style=\"font-size: 0.75rem; padding: 6px 16px;\">Consejo Superior Universitario\n          </div>\n\n          <!-- Line to Rectory and dotted connection -->\n          <div style=\"height: 25px; width: 1px; background: #b4b4b4; position: relative;\">\n            <div\n              style=\"position: absolute; left: -250px; top: -1px; width: 250px; height: 35px; border-top: 1px dashed #b4b4b4; border-left: 1px dashed #b4b4b4;\">\n            </div>\n          </div>\n\n          <div style=\"height: 25px; width: 1px; background: #b4b4b4; position: relative;\">\n            <div style=\"position: absolute; left: -250px; top: 0; width: 250px; height: 1px; background: #b4b4b4;\">\n            </div>\n            <div class=\"org-node node-green\"\n              style=\"position: absolute; left:-250px; top:0; transform: translate(-50%, -50%);\">Consejo Académico</div>\n          </div>\n\n          <!-- Rectoría -->\n          <div class=\"org-node node-green\" style=\"font-size: 0.8rem; padding: 8px 18px;\">RECTORÍA</div>\n        </div>\n\n        <!-- Main Trunk Area -->\n        <div style=\"display: flex; width: 100%; max-width: 900px; margin: 0 auto; position: relative;\">\n          <!-- Central Trunk -->\n          <div\n            style=\"position: absolute; left: 50%; top: 0; bottom: 0; width: 1px; background: #b4b4b4; transform: translateX(-50%);\">\n          </div>\n\n          <!-- Left Branches -->\n          <div\n            style=\"width: 50%; display: flex; flex-direction: column; align-items: flex-end; padding-top: 15px; padding-bottom: 25px; gap: 20px;\">\n            <!-- Secretaria Gen -->\n            <div\n              style=\"display: flex; align-items: flex-start; justify-content: flex-end; margin-right: -1px; margin-bottom: 5px;\">\n              <div style=\"display: flex; flex-direction: column; align-items: center; position: relative;\">\n                <div class=\"org-node node-green\">Secretaría General</div>\n                <!-- Vertical drop -->\n                <div style=\"width: 1px; height: 15px; background: #b4b4b4;\"></div>\n                <!-- Horizontal bridge -->\n                <div style=\"width: 250px; height: 1px; background: #b4b4b4; position: relative;\">\n                  <div style=\"position: absolute; left: 0; top: 0; width: 1px; height: 15px; background: #b4b4b4;\">\n                  </div>\n                  <div style=\"position: absolute; right: 0; top: 0; width: 1px; height: 15px; background: #b4b4b4;\">\n                  </div>\n                </div>\n                <!-- Nodes row -->\n                <div style=\"display: flex; justify-content: space-between; width: 250px; margin-top: 15px;\">\n                  <div style=\"display: flex; flex-direction: column; align-items: center;\">\n                    <div class=\"org-node node-orange\">Oficina de Gestión<br>Documental</div>\n                    <div style=\"width: 1px; height: 12px; background: #b4b4b4;\"></div>\n                    <div class=\"org-node node-purple\">División de Archivo</div>\n                  </div>\n                  <div>\n                    <div class=\"org-node node-orange\">Oficina de Atención<br>al Ciudadano</div>\n                  </div>\n                </div>\n              </div>\n              <div style=\"width: 20px; height: 1px; background: #b4b4b4; margin-top: 12px;\"></div>\n            </div>\n\n            <!-- Left Nodes -->\n            <div style=\"display: flex; align-items: center; margin-right: -1px;\">\n              <div class=\"org-node node-orange\">Oficina de Control<br>Interno Disciplinario</div>\n              <div style=\"width: 20px; height: 1px; background: #b4b4b4;\"></div>\n            </div>\n\n            <div style=\"display: flex; align-items: center; margin-right: -1px;\">\n              <div class=\"org-node node-orange\">Oficina de Control Interno<br>y de Gestión</div>\n              <div style=\"width: 20px; height: 1px; background: #b4b4b4;\"></div>\n            </div>\n\n            <!-- Aseguramiento Calidad -->\n            <div style=\"display: flex; align-items: flex-start; justify-content: flex-end; margin-right: -1px;\">\n              <div style=\"display: flex; flex-direction: column; align-items: center;\">\n                <div class=\"org-node node-orange\">Oficina de Aseguramiento<br>de la Calidad y la Acreditación</div>\n                <div style=\"width: 1px; height: 10px; background: #b4b4b4;\"></div>\n                <div class=\"org-node node-purple\">División de Autoevaluación<br>y Acreditación</div>\n              </div>\n              <div style=\"width: 20px; height: 1px; background: #b4b4b4; margin-top: 15px;\"></div>\n            </div>\n\n          </div>\n\n          <!-- Right Branches -->\n          <div\n            style=\"width: 50%; display: flex; flex-direction: column; align-items: flex-start; padding-top: 80px; gap: 20px;\">\n            <div style=\"display: flex; align-items: flex-start; margin-left: -1px;\">\n              <div style=\"width: 20px; height: 1px; background: #b4b4b4; margin-top: 15px;\"></div>\n              <div style=\"display: flex; align-items: center; gap: 15px;\">\n                <div class=\"org-node node-blue\">Oficina Asesora<br>de Planeación</div>\n                <div style=\"width: 20px; height: 1px; background: #b4b4b4;\"></div>\n                <div class=\"org-node node-purple\">División del Sistema<br>Integrado de Gestión</div>\n              </div>\n            </div>\n\n            <div style=\"display: flex; align-items: center; margin-left: -1px;\">\n              <div style=\"width: 20px; height: 1px; background: #b4b4b4;\"></div>\n              <div class=\"org-node node-blue\">Oficina Asesora Jurídica<br>y de Contratación</div>\n            </div>\n\n            <div style=\"display: flex; align-items: center; margin-left: -1px;\">\n              <div style=\"width: 20px; height: 1px; background: #b4b4b4;\"></div>\n              <div class=\"org-node node-blue\">Oficina Asesora de Prensa,<br>Comunicaciones y Mercadeo</div>\n            </div>\n\n            <div style=\"display: flex; align-items: center; margin-left: -1px;\">\n              <div style=\"width: 20px; height: 1px; background: #b4b4b4;\"></div>\n              <div class=\"org-node node-orange\">Oficina de Proyectos Especiales<br>y Relaciones Interinstitucionales\n              </div>\n            </div>\n\n            <div style=\"display: flex; align-items: center; margin-left: -1px;\">\n              <div style=\"width: 20px; height: 1px; background: #b4b4b4;\"></div>\n              <div class=\"org-node node-orange\">Oficina de Relaciones y<br>Cooperación Internacional</div>\n            </div>\n          </div>\n        </div>\n\n        <!-- Connection to 4 Columns -->\n        <div style=\"width: 1px; height: 25px; background: #b4b4b4; margin: 0 auto;\"></div>\n        <div style=\"display: flex; width: 95%; margin: 0 auto; justify-content: space-between; position: relative;\">\n          <!-- horizontal line -->\n          <div style=\"position: absolute; left: 12%; right: 12%; top: 0; height: 1px; background: #b4b4b4;\"></div>\n\n          <!-- Col 1 -->\n          <div class=\"v-col\">\n            <div class=\"org-vert-line\" style=\"height: 15px;\"></div>\n            <div class=\"org-node node-orange\" style=\"width: 80%;\">Vicerrectoría Académica</div>\n            <div class=\"org-vert-line\" style=\"height: 15px;\"></div>\n\n            <div class=\"v-box\">\n              <div class=\"v-spine\" style=\"bottom: auto; height: 85%;\"></div>\n              <div class=\"v-row\">\n                <div class=\"h-line-left\"></div>\n                <div class=\"org-node node-green v-node-lg\">Facultad de Artes</div>\n                <div class=\"h-line-mid\"></div>\n                <div class=\"org-node node-orange v-node-sm\">Oficina de Admisiones<br>y Registro</div>\n              </div>\n              <div class=\"v-row\">\n                <div class=\"h-line-left\"></div>\n                <div class=\"org-node node-green v-node-lg\">Facultad de Ciencias</div>\n                <div class=\"h-line-mid\"></div>\n                <div class=\"org-node node-orange v-node-sm\">Oficina de Bienestar<br>Universitario</div>\n              </div>\n              <div class=\"v-row\">\n                <div class=\"h-line-left\"></div>\n                <div class=\"org-node node-green v-node-lg\">Facultad de Ciencias<br>Económicas y Administrativas</div>\n              </div>\n              <div class=\"v-row\">\n                <div class=\"h-line-left\"></div>\n                <div class=\"org-node node-green v-node-lg\">Facultad de Derecho<br>y Ciencias Políticas</div>\n              </div>\n              <div class=\"v-row\">\n                <div class=\"h-line-left\"></div>\n                <div class=\"org-node node-green v-node-lg\">Facultad de Ingenierías</div>\n              </div>\n              <div class=\"v-row\">\n                <div class=\"h-line-left\"></div>\n                <div class=\"org-node node-green v-node-lg\">Escuela de Ciencias<br>del Lenguaje</div>\n              </div>\n              <div class=\"v-row\">\n                <div class=\"h-line-left\"></div>\n                <div class=\"org-node node-green v-node-lg\">Escuela de<br>Ciencias Humanas</div>\n              </div>\n              <div class=\"v-row\">\n                <div class=\"h-line-left\"></div>\n                <div class=\"org-node node-purple v-node-lg\">Biblioteca</div>\n              </div>\n            </div>\n          </div>\n\n          <!-- Col 2 -->\n          <div class=\"v-col\">\n            <div class=\"org-vert-line\" style=\"height: 15px;\"></div>\n            <div class=\"org-node node-orange\" style=\"width: 80%;\">Vicerrectoría de<br>Investigación</div>\n            <div class=\"org-vert-line\" style=\"height: 15px;\"></div>\n\n            <div class=\"v-box\">\n              <div class=\"v-spine\"></div>\n              <div class=\"v-row\">\n                <div class=\"h-line-left\"></div>\n                <div class=\"org-node node-green v-node-full\">Subdirección de Producción<br>y Divulgación de la\n                  Investigación</div>\n              </div>\n              <div class=\"v-row\">\n                <div class=\"h-line-left\"></div>\n                <div class=\"org-node node-green v-node-full\">Subdirección de Fomento de<br>la Investigación</div>\n              </div>\n              <div class=\"v-row\">\n                <div class=\"h-line-left\"></div>\n                <div class=\"org-node node-green v-node-full\">Subdirección Técnica<br>de la Investigación</div>\n              </div>\n            </div>\n          </div>\n\n          <!-- Col 3 -->\n          <div class=\"v-col\">\n            <div class=\"org-vert-line\" style=\"height: 15px;\"></div>\n            <div class=\"org-node node-orange\" style=\"width: 80%;\">Vicerrectoría de<br>Proyección Social</div>\n            <div class=\"org-vert-line\" style=\"height: 15px;\"></div>\n\n            <div class=\"v-box\">\n              <div class=\"v-spine\"></div>\n              <div class=\"v-row\">\n                <div class=\"h-line-left\"></div>\n                <div class=\"org-node node-purple v-node-full\">División de Emprendimiento</div>\n              </div>\n              <div class=\"v-row\">\n                <div class=\"h-line-left\"></div>\n                <div class=\"org-node node-purple v-node-full\">División de Egresados</div>\n              </div>\n              <div class=\"v-row\">\n                <div class=\"h-line-left\"></div>\n                <div class=\"org-node node-purple v-node-full\">División de<br>Educación Continuada</div>\n              </div>\n              <div class=\"v-row\">\n                <div class=\"h-line-left\"></div>\n                <div class=\"org-node node-purple v-node-full\">División de Articulación<br>con la Educación Media</div>\n              </div>\n            </div>\n          </div>\n\n          <!-- Col 4 -->\n          <div class=\"v-col\">\n            <div class=\"org-vert-line\" style=\"height: 15px;\"></div>\n            <div class=\"org-node node-orange\" style=\"width: 90%;\">Vicerrectoría Administrativa<br>y Financiera</div>\n            <div class=\"org-vert-line\" style=\"height: 15px;\"></div>\n\n            <div class=\"v-box\">\n              <div class=\"v-spine\" style=\"bottom: auto; height: 80%;\"></div>\n              <div class=\"v-row\">\n                <div class=\"h-line-left\"></div>\n                <div class=\"org-node node-orange v-node-admin\">Oficina de Talento Humano</div>\n                <div class=\"h-line-mid\"></div>\n                <div class=\"org-node node-purple v-node-admin-sm\">Tesorería</div>\n              </div>\n              <div class=\"v-row\">\n                <div class=\"h-line-left\"></div>\n                <div class=\"org-node node-purple v-node-admin\">División de Seguridad y<br>Salud en el Trabajo</div>\n                <div class=\"h-line-mid\"></div>\n                <div class=\"org-node node-purple v-node-admin-sm\">División de Sistemas de<br>Información y Tecnología\n                </div>\n              </div>\n              <div class=\"v-row\">\n                <div class=\"h-line-left\"></div>\n                <div class=\"org-node node-orange v-node-admin\">Subdirección de Contabilidad</div>\n                <div class=\"h-line-mid\"></div>\n                <div class=\"org-node node-purple v-node-admin-sm\">Granjas</div>\n              </div>\n              <div class=\"v-row\">\n                <div class=\"h-line-left\"></div>\n                <div class=\"org-node node-purple v-node-admin\">División de Presupuesto</div>\n              </div>\n              <div class=\"v-row\">\n                <div class=\"h-line-left\"></div>\n                <div class=\"org-node node-orange v-node-admin\">Subdirección de Infraestructura<br>y Recursos Físicos\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- Footer de la caja -->\n        <div\n          style=\"text-align: center; font-size: 0.75rem; color: #555; margin-top: 50px; border-top: 1px solid #e0e0e0; padding-top: 20px; font-weight: 500;\">\n          <strong style=\"color: #333; font-size: 0.85rem;\">Universidad Internacional del Trópico Americano / NIT.\n            844002071-4</strong><br>\n          Cra 19 N. 39 - 40 Ciudadela Universitaria, Yopal - Casanare, Colombia. &nbsp;|&nbsp; (601) 915 70 05\n          &nbsp;|&nbsp; vur@unitropico.edu.co &nbsp;|&nbsp; www.unitropico.edu.co\n        </div>\n\n      </div>\n    </div>\n  </div>\n\n</body>\n\n</html>",
  "allowScripts": true,
  "hotspots": []
}